              "type": "text"
            },
            {
              "key": "Name",
              "value": "",
              "type": "text"
            }
          ]
        },
        "url": {
          "raw": "{{baseUrl}}/backend/api/customer/kois/add.php",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
