# Môi trường chạy kịch bản kiểm thử API local
BASE_URL=http://localhost:8000
PROJECT_NAME=StudyHub
POSTMAN_COLLECTION_PATH=postman/collections

# Cấu hình kết nối Jira Cloud (Để tự động tạo Bug khi chạy test local)
# ĐỐI VỚI TEAM: Không được commit file .env chứa Token cá nhân lên Git.
JIRA_BASE_URL=https://your-domain.atlassian.net
JIRA_EMAIL=your-email@email.com
JIRA_API_TOKEN=your-jira-api-token
JIRA_PROJECT_KEY=SH
JIRA_ISSUE_TYPE=Bug
