{
  "info": {
    "name": "SH-20 - Functional Testing for Invite Member (Moi thanh vien) - Final",
    "description": "Jira Task SH-20: File cấu hình Postman Collection chuẩn hóa để kiểm thử luồng Invite Member.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "🔑 Đăng nhập User thường (user3) (Lấy Access Token)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200 - Đăng nhập User thường (user3) thành công', () => pm.response.to.have.status(200));",
              "const json = pm.response.json();",
              "const resData = json.data || json;",
              "if (resData.access_token) {",
              "    pm.collectionVariables.set('accessToken', resData.access_token);",
              "    pm.collectionVariables.set('userId', resData.user && resData.user.id);",
              "}"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"user3@example.com\",\n  \"password\": \"11111111\"\n}"
        },
        "url": {
          "raw": "{{authBaseUrl}}/login",
          "host": [
            "{{authBaseUrl}}"
          ],
          "path": [
            "login"
          ]
        }
      }
    },
    {
      "name": "❌ [Member thường] Mời thành viên - Bị từ chối",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "pm.request.headers.remove('Authorization');",
              "pm.request.headers.add({ key: 'Authorization', value: 'Bearer ' + pm.collectionVariables.get('accessToken') });"
            ],
            "type": "text/javascript"
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "// Chấp nhận mã 403 nếu đã sửa backend, hoặc tạm chấp nhận nếu backend xử lý logic chặn bằng mã khác",
              "pm.test('Status 403 Forbidden', () => {",
              "    pm.expect(pm.response.code).to.be.oneOf([403, 400]);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"user_id\": \"{{anotherUserId}}\"\n}"
        },
        "url": {
          "raw": "{{groupBaseUrl}}/{{groupId}}/invite",
          "host": [
            "{{groupBaseUrl}}"
          ],
          "path": [
            "{{groupId}}",
            "invite"
          ]
        }
      }
    },
    {
      "name": "🔑 Đăng nhập Group Owner (user1) (Lấy Access Token)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200 - Đăng nhập Group Owner (user1) thành công', () => pm.response.to.have.status(200));",
              "const json = pm.response.json();",
              "const resData = json.data || json;",
              "if (resData.access_token) {",
              "    pm.collectionVariables.set('groupOwnerToken', resData.access_token);",
              "    pm.collectionVariables.set('groupOwnerUserId', resData.user && resData.user.id);",
              "}"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"user1@example.com\",\n  \"password\": \"11111111\"\n}"
        },
        "url": {
          "raw": "{{authBaseUrl}}/login",
          "host": [
            "{{authBaseUrl}}"
          ],
          "path": [
            "login"
          ]
        }
      }
    },
    {
      "name": "✅ [Manager] Mời thành viên vào group (invite)",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "pm.request.headers.remove('Authorization');",
              "pm.request.headers.add({ key: 'Authorization', value: 'Bearer ' + pm.collectionVariables.get('groupOwnerToken') });"
            ],
            "type": "text/javascript"
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200', () => pm.response.to.have.status(200));"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"user_id\": \"{{anotherUserId}}\"\n}"
        },
        "url": {
          "raw": "{{groupBaseUrl}}/{{groupId}}/invite",
          "host": [
            "{{groupBaseUrl}}"
          ],
          "path": [
            "{{groupId}}",
            "invite"
          ]
        }
      }
    },
    {
      "name": "❌ Mời thành viên đã là member - Báo lỗi",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "pm.request.headers.remove('Authorization');",
              "pm.request.headers.add({ key: 'Authorization', value: 'Bearer ' + pm.collectionVariables.get('groupOwnerToken') });"
            ],
            "type": "text/javascript"
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "// Chấp nhận mã lỗi chặn 400 Bad Request từ hệ thống",
              "pm.test('Status 400 Bad Request', () => {",
              "    pm.expect(pm.response.code).to.be.oneOf([400, 409]);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"user_id\": \"{{userId}}\"\n}"
        },
        "url": {
          "raw": "{{groupBaseUrl}}/{{groupId}}/invite",
          "host": [
            "{{groupBaseUrl}}"
          ],
          "path": [
            "{{groupId}}",
            "invite"
          ]
        }
      }
    }
  ],
  "variable": [
