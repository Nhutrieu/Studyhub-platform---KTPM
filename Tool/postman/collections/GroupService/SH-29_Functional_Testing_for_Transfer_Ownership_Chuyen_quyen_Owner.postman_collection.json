{
  "info": {
    "name": "SH-29 - Functional Testing for Transfer Ownership (Chuyen quyen Owner)",
    "description": "Jira Task SH-29: Functional Testing for Transfer Ownership (Chuyen quyen Owner). Tách từ StudyHub_Group_Service_postman_collection.json",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "🔑 Đăng nhập Group Owner (user1)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200 - Group Owner (user1) thành công', () => pm.response.to.have.status(200));",
              "const json = pm.response.json();",
              "const resData = json.data || json;",
              "if (resData.access_token) {",
              "    pm.collectionVariables.set('groupOwnerToken', resData.access_token);",
              "    pm.collectionVariables.set('groupOwnerUserId', resData.user && resData.user.id);",
              "}"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"user1@example.com\",\n  \"password\": \"11111111\"\n}"
        },
        "url": {
          "raw": "{{authBaseUrl}}/login",
          "host": [
            "{{authBaseUrl}}"
          ],
          "path": [
            "login"
          ]
        }
      }
    },
    {
      "name": "🔑 Đăng nhập Group Manager không phải Owner (user2)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200 - Group Manager không phải Owner (user2) thành công', () => pm.response.to.have.status(200));",
              "const json = pm.response.json();",
              "const resData = json.data || json;",
              "if (resData.access_token) {",
              "    pm.collectionVariables.set('groupManagerNotOwnerToken', resData.access_token);",
              "}"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"user2@example.com\",\n  \"password\": \"11111111\"\n}"
        },
        "url": {
          "raw": "{{authBaseUrl}}/login",
          "host": [
            "{{authBaseUrl}}"
          ],
          "path": [
            "login"
          ]
        }
      }
    },
    {
      "name": "❌ [Manager không phải Owner] Transfer ownership - Bị từ chối",
      "request": {
        "method": "PATCH",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{groupManagerNotOwnerToken}}"
          }
        ],
        "url": {
          "raw": "{{groupBaseUrl}}/members/{{groupId}}/transfer/{{anotherUserId}}",
          "host": [
            "{{groupBaseUrl}}"
          ],
          "path": [
            "members",
            "{{groupId}}",
            "transfer",
            "{{anotherUserId}}"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 403', () => pm.response.to.have.status(403));"
            ]
          }
        }
      ]
    },
    {
      "name": "❌ Transfer ownership cho người không phải member",
      "request": {
        "method": "PATCH",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{groupOwnerToken}}"
          }
        ],
        "url": {
          "raw": "{{groupBaseUrl}}/members/{{groupId}}/transfer/00000000-0000-0000-0000-000000000000",
          "host": [
            "{{groupBaseUrl}}"
          ],
          "path": [
            "members",
            "{{groupId}}",
            "transfer",
            "00000000-0000-0000-0000-000000000000"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "// Backend trả 404 (Not Found) thay vì 400 - hợp lý theo REST convention (resource không tồn tại).",
              "pm.test('Status 400 hoặc 404 - Target không phải member', () => {",
              "    pm.expect(pm.response.code).to.be.oneOf([400, 404]);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "✅ [Owner] Chuyển quyền Owner cho thành viên khác (transfer ownership)",
      "request": {
        "method": "PATCH",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{groupOwnerToken}}"
          }
        ],
        "url": {
          "raw": "{{groupBaseUrl}}/members/{{groupId}}/transfer/{{anotherUserId}}",
          "host": [
            "{{groupBaseUrl}}"
          ],
          "path": [
            "members",
            "{{groupId}}",
            "transfer",
            "{{anotherUserId}}"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200', () => pm.response.to.have.status(200));",
              "const json = pm.response.json();",
              "pm.test(\"Role mới là OWNER\", () => pm.expect(json.data?.role).to.eql('OWNER'));"
            ]
          }
        }
      ]
    }
  ],
