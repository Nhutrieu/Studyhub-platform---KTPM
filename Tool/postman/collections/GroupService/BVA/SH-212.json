    {
      "name": "🧪 [BVA] [Manager] requests?limit=0 -> GroupService clamp Math.max(1, 0||50) = 50, KHÔNG lỗi",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "// [BVA - Boundary Value Analysis] Test case bo sung dua tren rang buoc thuc te trong source code backend.",
              "// GroupService.listJoinRequests: limit = Math.max(1, Number(limit) || 50); => 0 la falsy -> 50, roi Math.max(1,50)=50.",
              "pm.test('Status 200 - limit=0 duoc clamp an toan ve 50', () => pm.response.to.have.status(200));"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{groupOwnerToken}}"
          }
        ],
        "url": {
          "raw": "{{groupBaseUrl}}/aaaaaaaa-aaaa-4aaa-8aaa-aaaaaaaaaaa2/requests?limit=0",
          "host": [
            "{{groupBaseUrl}}"
          ],
          "path": [
            "aaaaaaaa-aaaa-4aaa-8aaa-aaaaaaaaaaa2",
            "requests"
          ],
          "query": [
            {
              "key": "limit",
              "value": "0"
            }
          ]
        }
      },
      "response": []
    },
