          "script": {
            "exec": [
              "// [BVA - Boundary Value Analysis] Test case bo sung dua tren rang buoc thuc te trong source code backend.",
              "// Controller dung pattern: const limitNum = Number(limit) || 50; Number(0) la falsy nen se fallback ve 50.",
              "pm.test('Status 200 - limit=0 khong gay loi, fallback ve mac dinh 50', () => pm.response.to.have.status(200));"
            ],
            "type": "text/javascript"
          }
