{
  "info": {
    "name": "StudyHub - SH-252 - Kiem thu BVA Moi thanh vien ",
    "description": "Bộ test case BVA tối ưu cho tính năng Mời thành viên, xử lý linh hoạt thứ tự kiểm tra Quyền (403) và Validate Biên (400).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "authBaseUrl",
      "value": "http://localhost:3000/api/v1/auth",
      "type": "string"
    },
    {
      "key": "groupBaseUrl",
      "value": "http://localhost:3002/api/v1/group",
      "type": "string"
    },
    {
      "key": "accessToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "userId",
      "value": "",
      "type": "string"
    },
    {
      "key": "groupId",
      "value": "aaaaaaaa-aaaa-4aaa-8aaa-aaaaaaaaaaa1",
      "type": "string"
    },
    {
      "key": "userEmail",
      "value": "user3@example.com",
      "type": "string"
    },
    {
      "key": "password",
      "value": "11111111",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "[SETUP] Dang nhap lay accessToken",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "{{authBaseUrl}}/login",
          "host": [
            "{{authBaseUrl}}"
          ],
          "path": [
            "login"
          ]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{userEmail}}\",\n  \"password\": \"{{password}}\"\n}"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 200 - Dang nhap thanh cong', () => pm.response.to.have.status(200));",
              "var json = pm.response.json();",
              "var data = json.data || json;",
              "if (data.access_token) {",
              "    pm.collectionVariables.set('accessToken', data.access_token);",
              "    pm.collectionVariables.set('userId', data.user && data.user.id);",
              "}"
            ]
          }
        }
      ]
    },
    {
      "name": "TC_01: Hop le Bien Min / Max / Nominal (user_id dung chuan format 36 ky tu)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}"
          }
        ],
        "url": {
          "raw": "{{groupBaseUrl}}/{{groupId}}/invite",
          "host": [
            "{{groupBaseUrl}}"
          ],
          "path": [
            "{{groupId}}",
            "invite"
          ]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"user_id\": \"11111111-2222-4222-8222-111111111112\"\n}"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200, 201 hoac 403 Forbidden', () => {",
              "    pm.expect(pm.response.code).to.be.oneOf([200, 201, 403]);",
              "});"
            ]
          }
        }
      ]
    },
