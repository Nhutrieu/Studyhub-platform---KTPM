            ],
            "type": "text/javascript"
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200/403 - role viết thường được tự động chuẩn hoá (case-insensitive theo thiết kế)', () => {\n    pm.expect(pm.response.code).to.be.oneOf([200, 403]);\n});"
            ]
          }
        }
      ],
      "request": {
        "method": "PATCH",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"role\": \"member\"\n}"
        },
        "url": {
          "raw": "{{groupBaseUrl}}/members/{{groupId}}/user/{{anotherUserId}}/role",
          "host": [
            "{{groupBaseUrl}}"
          ],
          "path": [
            "members",
            "{{groupId}}",
            "user",
            "{{anotherUserId}}",
            "role"
          ]
        }
      }
    },
    {
      "name": "❌ BVA-4 Biên trống không hợp lệ: role=\"\"",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "pm.request.headers.remove('Authorization');",
