            ],
            "type": "text/javascript"
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 400 - role rỗng bị từ chối', () => pm.response.to.have.status(400));"
            ]
          }
        }
      ],
      "request": {
        "method": "PATCH",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"role\": \"\"\n}"
        },
        "url": {
          "raw": "{{groupBaseUrl}}/members/{{groupId}}/user/{{anotherUserId}}/role",
          "host": [
            "{{groupBaseUrl}}"
          ],
          "path": [
            "members",
            "{{groupId}}",
            "user",
            "{{anotherUserId}}",
            "role"
          ]
        }
      }
    },
