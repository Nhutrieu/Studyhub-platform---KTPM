            "type": "text/javascript"
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200/403 - role=MODERATOR hợp lệ', () => {\n    pm.expect(pm.response.code).to.be.oneOf([200, 403]);\n});"
            ]
          }
        }
      ],
      "request": {
        "method": "PATCH",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"role\": \"MODERATOR\"\n}"
        },
        "url": {
          "raw": "{{groupBaseUrl}}/members/{{groupId}}/user/{{anotherUserId}}/role",
          "host": [
            "{{groupBaseUrl}}"
          ],
          "path": [
            "members",
            "{{groupId}}",
            "user",
            "{{anotherUserId}}",
            "role"
          ]
        }
      }
    },
    {
      "name": "✅ BVA-3 Chuẩn hoá chữ hoa/thường: role=\"member\" (chữ thường, hệ thống tự viết hoa)",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "pm.request.headers.remove('Authorization');",
