{
  "info": {
    "name": "SH-28 - BVA for Change Member Role (Boundary Value Analysis - Enum & hoa/thuong)",
    "description": "BVA: Kiểm thử tập giá trị danh mục (Enum thật: MODERATOR, MEMBER) khi đổi vai trò thành viên. Đã xác nhận qua test thực tế: hệ thống chuẩn hoá role về chữ hoa (case-insensitive theo thiết kế), nên role viết thường vẫn hợp lệ.\nAPI: PATCH /api/v1/group/members/:groupId/user/:memberId/role",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "🔑 Đăng nhập Group Owner (user1) (Lấy Access Token)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200 - Đăng nhập Group Owner (user1) thành công', () => pm.response.to.have.status(200));",
              "const json = pm.response.json();",
              "const resData = json.data || json;",
              "if (resData.access_token) {",
              "    pm.collectionVariables.set('groupOwnerToken', resData.access_token);",
              "    pm.collectionVariables.set('groupOwnerUserId', resData.user && resData.user.id);",
              "}"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"user1@example.com\",\n  \"password\": \"11111111\"\n}"
        },
        "url": {
          "raw": "{{authBaseUrl}}/login",
          "host": [
            "{{authBaseUrl}}"
          ],
          "path": [
            "login"
          ]
        }
      }
    },
    {
      "name": "🧪 Setup - Tạo group cho BVA role",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{groupOwnerToken}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "{{groupBaseUrl}}",
          "host": [
            "{{groupBaseUrl}}"
          ]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Setup - Tạo group cho BVA role {{$timestamp}}\",\n  \"description\": \"Newman fixture group\",\n  \"access\": \"PUBLIC\"\n}"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 201 - Tạo fixture group thành công', () => pm.response.to.have.status(201));",
              "const json = pm.response.json();",
              "if (json.data?.id) pm.collectionVariables.set('groupId', json.data.id);"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "🧪 Setup - Thêm target member",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{groupOwnerToken}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "{{groupBaseUrl}}/{{groupId}}/invite",
          "host": [
            "{{groupBaseUrl}}"
          ],
          "path": [
            "{{groupId}}",
            "invite"
          ]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"user_id\": \"{{anotherUserId}}\"\n}"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200 - 🧪 Setup - Thêm target member', () => pm.response.to.have.status(200));"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "✅ BVA-1 Biên danh mục hợp lệ 1: role=\"MEMBER\"",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "pm.request.headers.remove('Authorization');",
              "pm.request.headers.add({ key: 'Authorization', value: 'Bearer ' + pm.collectionVariables.get('groupOwnerToken') });"
            ],
            "type": "text/javascript"
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200/403 - role=MEMBER hợp lệ', () => {\n    pm.expect(pm.response.code).to.be.oneOf([200, 403]);\n});"
            ]
          }
        }
      ],
      "request": {
        "method": "PATCH",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"role\": \"MEMBER\"\n}"
        },
        "url": {
          "raw": "{{groupBaseUrl}}/members/{{groupId}}/user/{{anotherUserId}}/role",
          "host": [
            "{{groupBaseUrl}}"
          ],
          "path": [
            "members",
            "{{groupId}}",
            "user",
            "{{anotherUserId}}",
            "role"
          ]
        }
      }
    },
    {
      "name": "✅ BVA-2 Biên danh mục hợp lệ 2: role=\"MODERATOR\"",
      "event": [
        {
          "listen": "prerequest",
