{
  "info": {
    "name": "SH-22 - BVA for Group Info Update (Boundary Value Analysis - do dai ten & mo ta nhom)",
    "description": "BVA: Kiểm thử giới hạn độ dài group_name (Min=3, Max=50) và description (Max=500).\nAPI: PATCH /api/v1/group/:groupId",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "🔑 Đăng nhập Group Owner (user2) (Lấy Access Token)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200 - Đăng nhập Group Owner (user2) thành công', () => pm.response.to.have.status(200));",
              "const json = pm.response.json();",
              "const resData = json.data || json;",
              "if (resData.access_token) {",
              "    pm.collectionVariables.set('groupOwnerToken', resData.access_token);",
              "    pm.collectionVariables.set('groupOwnerUserId', resData.user && resData.user.id);",
              "}"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"user2@example.com\",\n  \"password\": \"11111111\"\n}"
        },
        "url": {
          "raw": "{{authBaseUrl}}/login",
          "host": [
            "{{authBaseUrl}}"
          ],
          "path": [
            "login"
          ]
        }
      }
    },
    {
      "name": "✅ BVA-1 Biên tối thiểu tên hợp lệ: group_name đúng 3 ký tự",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "pm.request.headers.remove('Authorization');",
              "pm.request.headers.add({ key: 'Authorization', value: 'Bearer ' + pm.collectionVariables.get('groupOwnerToken') });"
            ],
            "type": "text/javascript"
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200/403 - group_name 3 ký tự hợp lệ', () => {\n    pm.expect(pm.response.code).to.be.oneOf([200, 403]);\n});"
            ]
          }
        }
      ],
      "request": {
        "method": "PATCH",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"abc\"\n}"
        },
        "url": {
          "raw": "{{groupBaseUrl}}/{{groupId}}",
          "host": [
            "{{groupBaseUrl}}"
          ],
          "path": [
            "{{groupId}}"
          ]
        }
      }
    },
