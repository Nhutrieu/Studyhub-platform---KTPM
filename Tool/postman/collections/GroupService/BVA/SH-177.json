{
  "info": {
    "name": "SH-25 - BVA for Member List (Boundary Value Analysis - phan trang tuong quan du lieu thuc te)",
    "description": "BVA: Kiểm thử tương quan giữa tham số phân trang (limit/offset) và tổng số thành viên thực tế (N) hiện có trong nhóm.\nAPI: GET /api/v1/group/members/group/:groupId",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "🔑 Đăng nhập User thường (user1) (Lấy Access Token)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200 - Đăng nhập User thường (user1) thành công', () => pm.response.to.have.status(200));",
              "const json = pm.response.json();",
              "const resData = json.data || json;",
              "if (resData.access_token) {",
              "    pm.collectionVariables.set('accessToken', resData.access_token);",
              "    pm.collectionVariables.set('userId', resData.user && resData.user.id);",
              "}"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"user1@example.com\",\n  \"password\": \"11111111\"\n}"
        },
        "url": {
          "raw": "{{authBaseUrl}}/login",
          "host": [
            "{{authBaseUrl}}"
          ],
          "path": [
            "login"
          ]
        }
      }
    },
    {
      "name": "🧪 Setup - Tạo group cho BVA member list",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "{{groupBaseUrl}}",
          "host": [
            "{{groupBaseUrl}}"
          ]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Setup - Tạo group cho BVA member list {{$timestamp}}\",\n  \"description\": \"Newman fixture group\",\n  \"access\": \"PUBLIC\"\n}"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 201 - Tạo fixture group thành công', () => pm.response.to.have.status(201));",
              "const json = pm.response.json();",
              "if (json.data?.id) pm.collectionVariables.set('groupId', json.data.id);"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "🧪 Setup - Thêm user7 để N > 1",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "{{groupBaseUrl}}/{{groupId}}/invite",
          "host": [
            "{{groupBaseUrl}}"
          ],
          "path": [
            "{{groupId}}",
            "invite"
          ]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"user_id\": \"11111111-2222-4222-8222-111111111118\"\n}"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200 - 🧪 Setup - Thêm user7 để N > 1', () => pm.response.to.have.status(200));"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "🔧 Setup - Lấy tổng số thành viên thực tế (N)",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "pm.request.headers.remove('Authorization');",
              "pm.request.headers.add({ key: 'Authorization', value: 'Bearer ' + pm.collectionVariables.get('accessToken') });"
            ],
            "type": "text/javascript"
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200 - Lấy danh sách thành viên thành công', () => pm.response.to.have.status(200));",
              "const json = pm.response.json();",
              "const resData = json.data || json;",
              "const list = Array.isArray(resData) ? resData : (resData.members || resData.items || []);",
              "const total = (resData.total !== undefined) ? resData.total : list.length;",
              "pm.collectionVariables.set('totalMembers', total);",
              "pm.collectionVariables.set('nMinus1', Math.max(total - 1, 0));",
              "pm.collectionVariables.set('nPlus1', total + 1);",
              "console.log('Tổng số thành viên thực tế N =', total);"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{groupBaseUrl}}/members/group/{{groupId}}?limit=1000&offset=0",
          "host": [
            "{{groupBaseUrl}}"
          ],
          "path": [
            "members",
            "group",
            "{{groupId}}"
          ],
          "query": [
            {
              "key": "limit",
              "value": "1000"
            },
            {
              "key": "offset",
              "value": "0"
            }
          ]
        }
      }
    },
    {
      "name": "✅ BVA-1 Biên tối thiểu hợp lệ: limit=1&offset=0",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "pm.request.headers.remove('Authorization');",
              "pm.request.headers.add({ key: 'Authorization', value: 'Bearer ' + pm.collectionVariables.get('accessToken') });"
            ],
            "type": "text/javascript"
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200 - limit=1', () => pm.response.to.have.status(200));"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{groupBaseUrl}}/members/group/{{groupId}}?limit=1&offset=0",
          "host": [
            "{{groupBaseUrl}}"
          ],
          "path": [
            "members",
            "group",
            "{{groupId}}"
          ],
          "query": [
            {
              "key": "limit",
              "value": "1"
            },
            {
              "key": "offset",
              "value": "0"
            }
          ]
        }
      }
    },
    {
      "name": "✅ BVA-2 Biên trùng khớp thực tế: limit=N",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "pm.request.headers.remove('Authorization');",
              "pm.request.headers.add({ key: 'Authorization', value: 'Bearer ' + pm.collectionVariables.get('accessToken') });"
            ],
            "type": "text/javascript"
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200 - limit=N', () => pm.response.to.have.status(200));",
              "const json = pm.response.json();",
              "const resData = json.data || json;",
              "const list = Array.isArray(resData) ? resData : (resData.members || resData.items || []);",
              "const N = parseInt(pm.collectionVariables.get('totalMembers'));",
              "pm.test('Số bản ghi trả về đúng bằng N (lấy vừa vặn toàn bộ danh sách)', () => {",
              "    pm.expect(list.length).to.eql(N);",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{groupBaseUrl}}/members/group/{{groupId}}?limit={{totalMembers}}&offset=0",
          "host": [
            "{{groupBaseUrl}}"
          ],
          "path": [
            "members",
            "group",
            "{{groupId}}"
          ],
          "query": [
            {
              "key": "limit",
              "value": "{{totalMembers}}"
            },
            {
              "key": "offset",
              "value": "0"
            }
          ]
        }
      }
    },
    {
      "name": "✅ BVA-3 Biên cận dưới thực tế: limit=N-1",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "pm.request.headers.remove('Authorization');",
              "pm.request.headers.add({ key: 'Authorization', value: 'Bearer ' + pm.collectionVariables.get('accessToken') });"
            ],
            "type": "text/javascript"
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200 - limit=N-1', () => pm.response.to.have.status(200));",
              "const json = pm.response.json();",
              "const resData = json.data || json;",
              "const list = Array.isArray(resData) ? resData : (resData.members || resData.items || []);",
              "const NMinus1 = parseInt(pm.collectionVariables.get('nMinus1'));",
              "pm.test('Số bản ghi trả về đúng bằng N-1 (lấy thiếu đúng 1 phần tử)', () => {",
              "    pm.expect(list.length).to.eql(NMinus1);",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{groupBaseUrl}}/members/group/{{groupId}}?limit={{nMinus1}}&offset=0",
          "host": [
            "{{groupBaseUrl}}"
          ],
          "path": [
            "members",
            "group",
            "{{groupId}}"
          ],
          "query": [
            {
              "key": "limit",
              "value": "{{nMinus1}}"
            },
            {
              "key": "offset",
              "value": "0"
            }
          ]
        }
      }
    },
    {
      "name": "✅ BVA-4 Biên cận trên thực tế: limit=N+1",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "pm.request.headers.remove('Authorization');",
              "pm.request.headers.add({ key: 'Authorization', value: 'Bearer ' + pm.collectionVariables.get('accessToken') });"
            ],
            "type": "text/javascript"
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200 - limit=N+1', () => pm.response.to.have.status(200));",
              "const json = pm.response.json();",
              "const resData = json.data || json;",
              "const list = Array.isArray(resData) ? resData : (resData.members || resData.items || []);",
              "const N = parseInt(pm.collectionVariables.get('totalMembers'));",
              "pm.test('Yêu cầu thừa 1 phần tử nhưng chỉ trả về đúng N bản ghi thực có', () => {",
              "    pm.expect(list.length).to.eql(N);",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{groupBaseUrl}}/members/group/{{groupId}}?limit={{nPlus1}}&offset=0",
          "host": [
            "{{groupBaseUrl}}"
          ],
          "path": [
            "members",
            "group",
            "{{groupId}}"
          ],
          "query": [
            {
              "key": "limit",
              "value": "{{nPlus1}}"
            },
            {
              "key": "offset",
              "value": "0"
            }
          ]
        }
      }
    },
    {
      "name": "❌ BVA-5 Biên lỗi tham số: limit=-5 hoặc offset=-1",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "pm.request.headers.remove('Authorization');",
              "pm.request.headers.add({ key: 'Authorization', value: 'Bearer ' + pm.collectionVariables.get('accessToken') });"
            ],
            "type": "text/javascript"
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 400 - limit/offset âm không hợp lệ', () => pm.response.to.have.status(400));"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{groupBaseUrl}}/members/group/{{groupId}}?limit=-5&offset=-1",
          "host": [
            "{{groupBaseUrl}}"
          ],
          "path": [
            "members",
            "group",
            "{{groupId}}"
          ],
          "query": [
            {
              "key": "limit",
              "value": "-5"
            },
            {
              "key": "offset",
              "value": "-1"
            }
          ]
        }
      }
    }
  ],
