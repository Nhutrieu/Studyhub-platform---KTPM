{
  "info": {
    "name": "StudyHub - SH-209 - Exhaustive BVA Testing for Join Group",
    "description": "Bộ test case BVA toàn diện mở rộng cho tính năng Tham gia nhóm, kiểm thử từ độ dài cực tiểu, cận biên, vượt biên cho tới cấu trúc chuỗi của thuộc tính CHAR(36).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "authBaseUrl",
      "value": "http://localhost:3000/api/v1/auth",
      "type": "string"
    },
    {
      "key": "groupBaseUrl",
      "value": "http://localhost:3002/api/v1/group",
      "type": "string"
    },
    {
      "key": "accessToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "userId",
      "value": "",
      "type": "string"
    },
    {
      "key": "password",
      "value": "11111111",
      "type": "string"
    },
    {
      "key": "userEmail",
      "value": "user1@example.com",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "[SETUP] Dang nhap user thuong (lay accessToken)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "{{authBaseUrl}}/login",
          "host": [
            "{{authBaseUrl}}"
          ],
          "path": [
            "login"
          ]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{userEmail}}\",\n  \"password\": \"{{password}}\"\n}"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 200 - dang nhap thanh cong', () => pm.response.to.have.status(200));",
              "var json = pm.response.json();",
              "var data = json.data || json;",
              "if (data.access_token) {",
              "    pm.collectionVariables.set('accessToken', data.access_token);",
              "    pm.collectionVariables.set('userId', data.user && data.user.id);",
              "}"
            ]
          }
        }
      ]
    },
    {
      "name": "TC_01: Bien trong / thieu han groupId (0 ky tu - Min-1)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}"
          }
        ],
        "url": {
          "raw": "{{groupBaseUrl}}//join",
          "host": [
            "{{groupBaseUrl}}"
          ],
          "path": [
            "",
            "join"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 404 hoac 400 - Thieu tham so duong dan', () => {",
              "    pm.expect(pm.response.code).to.be.oneOf([400, 404]);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "TC_02: Bien cuc tieu chuoi han hieu (1 ky tu - Min)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}"
          }
        ],
        "url": {
          "raw": "{{groupBaseUrl}}/a/join",
          "host": [
            "{{groupBaseUrl}}"
          ],
          "path": [
            "a",
            "join"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 400 hoac 404 - Id qua ngan', () => {",
              "    pm.expect(pm.response.code).to.be.oneOf([400, 404]);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "TC_03: Bien thieu 1 ky tu (35 ky tu - Can duoi biên)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}"
          }
        ],
        "url": {
          "raw": "{{groupBaseUrl}}/aaaaaaaa-aaaa-4aaa-8aaa-aaaaaaaaaaa/join",
          "host": [
            "{{groupBaseUrl}}"
          ],
          "path": [
            "aaaaaaaa-aaaa-4aaa-8aaa-aaaaaaaaaaa",
            "join"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 400 hoac 404 - group_id thieu ky tu', () => {",
              "    pm.expect(pm.response.code).to.be.oneOf([400, 404]);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "TC_04: Dung 36 ky tu nhung sai vi tri gach ngang (Bien cau truc format)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}"
          }
        ],
        "url": {
          "raw": "{{groupBaseUrl}}/aaaaaaaaaaaa4aaa8aaaaaaaaaaaaaaaaaaa/join",
          "host": [
            "{{groupBaseUrl}}"
          ],
          "path": [
            "aaaaaaaaaaaa4aaa8aaaaaaaaaaaaaaaaaaa",
            "join"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 400 hoac 404 - Sai format UUID du 36 ky tu', () => {",
              "    pm.expect(pm.response.code).to.be.oneOf([400, 404]);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "TC_05: Bien du 1 ky tu (37 ky tu - Can tren biên)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}"
          }
        ],
        "url": {
          "raw": "{{groupBaseUrl}}/aaaaaaaa-aaaa-4aaa-8aaa-aaaaaaaaaaa22/join",
          "host": [
            "{{groupBaseUrl}}"
          ],
          "path": [
            "aaaaaaaa-aaaa-4aaa-8aaa-aaaaaaaaaaa22",
            "join"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 400 hoac 404 - group_id du ky tu', () => {",
              "    pm.expect(pm.response.code).to.be.oneOf([400, 404]);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "TC_06: Bien do dai cuc dai vuot nguong (255 ky tu - Max Web Server/ORM)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}"
          }
        ],
        "url": {
          "raw": "{{groupBaseUrl}}/aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa/join",
          "host": [
            "{{groupBaseUrl}}"
          ],
          "path": [
            "aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa",
            "join"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 400, 404 hoac 414 - Do dai vuot nguong cho phep', () => {",
              "    pm.expect([400, 404, 414]).to.include(pm.response.code);",
              "});"
            ]
          }
        }
      ]
    }
  ]
}