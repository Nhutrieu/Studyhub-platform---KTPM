    {
      "name": "🧪 Tạo group dùng cho test xóa",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{groupOwnerToken}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"SH-23 Delete {{$timestamp}}\",\n  \"description\": \"Fixture group for delete test\",\n  \"access\": \"PUBLIC\"\n}"
        },
        "url": {
          "raw": "{{groupBaseUrl}}",
          "host": [
            "{{groupBaseUrl}}"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 201 - Tạo group delete thành công', () => pm.response.to.have.status(201));",
              "const json = pm.response.json();",
              "if (json.data?.id) pm.collectionVariables.set('emptyGroupId', json.data.id);"
            ]
          }
        }
      ]
    },
