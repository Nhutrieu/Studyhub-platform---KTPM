            ]
          }
        }
      ]
    },
    {
      "name": "❌ Duyệt/từ chối request_id không tồn tại",
      "request": {
        "method": "PATCH",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{groupOwnerToken}}"
          }
        ],
        "url": {
          "raw": "{{groupBaseUrl}}/requests/{{groupId}}/00000000-0000-0000-0000-000000000000/approve",
          "host": [
            "{{groupBaseUrl}}"
          ],
          "path": [
            "requests",
            "{{groupId}}",
            "00000000-0000-0000-0000-000000000000",
            "approve"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 400 - Từ chối thành công do request_id không tồn tại', () => pm.response.to.have.status(400));"
            ]
          }
        }
      ]
    }
