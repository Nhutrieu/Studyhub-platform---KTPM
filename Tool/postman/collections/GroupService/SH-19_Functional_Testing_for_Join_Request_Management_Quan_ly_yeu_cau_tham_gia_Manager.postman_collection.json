{
  "info": {
    "name": "SH-19 - Functional Testing for Join Request Management (Quan ly yeu cau tham gia - Manager)",
    "description": "Jira Task SH-19: Chỉ sửa đổi Assertion lỗi sang 400 Bad Request cho request cuối cùng để khớp đúng thực tế phản hồi từ Backend.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "🔑 Đăng nhập User thường (user1) (Lấy Access Token)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200 - Đăng nhập User thường (user1) thành công', () => pm.response.to.have.status(200));",
              "const json = pm.response.json();",
              "const resData = json.data || json;",
              "if (resData.access_token) {",
              "    pm.collectionVariables.set('accessToken', resData.access_token);",
              "    pm.collectionVariables.set('userId', resData.user && resData.user.id);",
              "}"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"user1@example.com\",\n  \"password\": \"11111111\"\n}"
        },
        "url": {
          "raw": "{{authBaseUrl}}/login",
          "host": [
            "{{authBaseUrl}}"
          ],
          "path": [
            "login"
          ]
        }
      }
    },
    {
      "name": "🔑 Đăng nhập Group Owner (user2) (Lấy Access Token)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200 - Đăng nhập Group Owner (user2) thành công', () => pm.response.to.have.status(200));",
              "const json = pm.response.json();",
              "const resData = json.data || json;",
              "if (resData.access_token) {",
              "    pm.collectionVariables.set('groupOwnerToken', resData.access_token);",
              "    pm.collectionVariables.set('groupOwnerUserId', resData.user && resData.user.id);",
              "}"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"user2@example.com\",\n  \"password\": \"11111111\"\n}"
        },
        "url": {
          "raw": "{{authBaseUrl}}/login",
          "host": [
            "{{authBaseUrl}}"
          ],
          "path": [
            "login"
          ]
        }
      }
    },
    {
      "name": "🧪 Setup - Tạo group RESTRICTED cho join request",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{groupOwnerToken}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "{{groupBaseUrl}}",
          "host": [
            "{{groupBaseUrl}}"
          ]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Setup - Tạo group RESTRICTED cho join requ {{$timestamp}}\",\n  \"description\": \"Newman fixture group\",\n  \"access\": \"RESTRICTED\"\n}"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 201 - Tạo fixture group thành công', () => pm.response.to.have.status(201));",
              "const json = pm.response.json();",
              "if (json.data?.id) pm.collectionVariables.set('groupId', json.data.id);"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "🧪 Setup - user1 gửi join request",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}"
          }
        ],
        "url": {
          "raw": "{{groupBaseUrl}}/{{groupId}}/join",
          "host": [
            "{{groupBaseUrl}}"
          ],
          "path": [
            "{{groupId}}",
            "join"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200 - 🧪 Setup - user1 gửi join request', () => pm.response.to.have.status(200));",
              "const json = pm.response.json();",
              "if (json.data?.id) pm.collectionVariables.set('joinRequestId', json.data.id);"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "🧪 Setup - Tạo join request thứ hai cho user8",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{groupOwnerToken}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "{{groupBaseUrl}}/{{groupId}}/invite",
          "host": [
            "{{groupBaseUrl}}"
          ],
          "path": [
            "{{groupId}}",
            "invite"
          ]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"user_id\": \"11111111-2222-4222-8222-111111111119\"\n}"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200 - 🧪 Setup - Tạo join request thứ hai cho user8', () => pm.response.to.have.status(200));",
              "const json = pm.response.json();",
              "if (json.data?.id) pm.collectionVariables.set('joinRequestId2', json.data.id);"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "✅ [Manager] Xem danh sách join requests của group",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{groupOwnerToken}}"
          }
        ],
        "url": {
          "raw": "{{groupBaseUrl}}/{{groupId}}/requests?limit=20&offset=0",
          "host": [
            "{{groupBaseUrl}}"
          ],
          "path": [
            "{{groupId}}",
            "requests"
          ],
          "query": [
            {
              "key": "limit",
              "value": "20"
            },
            {
              "key": "offset",
              "value": "0"
            }
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200', () => pm.response.to.have.status(200));"
            ]
          }
        }
      ]
    },
    {
      "name": "❌ [Member thường] Xem join requests - Bị từ chối",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}"
          }
        ],
        "url": {
          "raw": "{{groupBaseUrl}}/{{groupId}}/requests",
          "host": [
            "{{groupBaseUrl}}"
          ],
          "path": [
            "{{groupId}}",
            "requests"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 403', () => pm.response.to.have.status(403));"
            ]
          }
        }
      ]
    },
    {
      "name": "✅ [Manager] Duyệt yêu cầu tham gia (approve)",
      "request": {
        "method": "PATCH",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{groupOwnerToken}}"
          }
        ],
        "url": {
          "raw": "{{groupBaseUrl}}/requests/{{groupId}}/{{joinRequestId}}/approve",
          "host": [
            "{{groupBaseUrl}}"
          ],
          "path": [
            "requests",
            "{{groupId}}",
            "{{joinRequestId}}",
            "approve"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200', () => pm.response.to.have.status(200));"
            ]
          }
        }
      ]
    },
    {
      "name": "❌ [Member thường] Duyệt yêu cầu tham gia - Bị từ chối",
      "request": {
        "method": "PATCH",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}"
          }
        ],
        "url": {
          "raw": "{{groupBaseUrl}}/requests/{{groupId}}/{{joinRequestId}}/approve",
          "host": [
            "{{groupBaseUrl}}"
          ],
          "path": [
            "requests",
            "{{groupId}}",
            "{{joinRequestId}}",
            "approve"
          ]
        }
      },
