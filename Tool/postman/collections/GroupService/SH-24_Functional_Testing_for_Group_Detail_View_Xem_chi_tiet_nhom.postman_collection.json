{
  "info": {
    "name": "SH-24 - Functional Testing for Group Detail View (Xem chi tiet nhom)",
    "description": "Jira Task SH-24: Functional Testing for Group Detail View (Xem chi tiet nhom). Tách từ StudyHub_Group_Service_postman_collection.json",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "🔑 Đăng nhập User thường (user1) (Lấy Access Token)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200 - Đăng nhập User thường (user1) thành công', () => pm.response.to.have.status(200));",
              "const json = pm.response.json();",
              "const resData = json.data || json;",
              "if (resData.access_token) {",
              "    pm.collectionVariables.set('accessToken', resData.access_token);",
              "    pm.collectionVariables.set('userId', resData.user && resData.user.id);",
              "}"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"user1@example.com\",\n  \"password\": \"11111111\"\n}"
        },
        "url": {
          "raw": "{{authBaseUrl}}/login",
          "host": [
            "{{authBaseUrl}}"
          ],
          "path": [
            "login"
          ]
        }
      }
    },
    {
      "name": "🧪 Setup - Tạo fixture group",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "{{groupBaseUrl}}",
          "host": [
            "{{groupBaseUrl}}"
          ]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Setup - Tạo fixture group {{$timestamp}}\",\n  \"description\": \"Newman fixture group\",\n  \"access\": \"PUBLIC\"\n}"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 201 - Tạo fixture group thành công', () => pm.response.to.have.status(201));",
              "const json = pm.response.json();",
              "if (json.data?.id) pm.collectionVariables.set('groupId', json.data.id);"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "✅ Xem chi tiết group",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}"
          }
        ],
        "url": {
          "raw": "{{groupBaseUrl}}/{{groupId}}",
          "host": [
            "{{groupBaseUrl}}"
          ],
          "path": [
            "{{groupId}}"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200', () => pm.response.to.have.status(200));",
              "pm.test('Có field success và data', () => { const j = pm.response.json(); pm.expect(j).to.have.property('success'); pm.expect(j).to.have.property('data'); });"
            ]
          }
        }
      ]
    },
    {
      "name": "❌ Xem chi tiết group - group_id không tồn tại",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}"
          }
        ],
        "url": {
          "raw": "{{groupBaseUrl}}/00000000-0000-0000-0000-000000000000",
          "host": [
            "{{groupBaseUrl}}"
          ],
          "path": [
            "00000000-0000-0000-0000-000000000000"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 404', () => pm.response.to.have.status(404));"
            ]
          }
        }
      ]
    },
    {
      "name": "❌ Xem chi tiết group - không có token",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{groupBaseUrl}}/{{groupId}}",
          "host": [
            "{{groupBaseUrl}}"
          ],
          "path": [
            "{{groupId}}"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 401', () => pm.response.to.have.status(401));"
            ]
          }
        }
      ]
    }
  ],
