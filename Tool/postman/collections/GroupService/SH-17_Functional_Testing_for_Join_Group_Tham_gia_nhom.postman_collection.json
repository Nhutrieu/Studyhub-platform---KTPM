{
  "info": {
    "name": "SH-17 - Functional Testing for Join Group (Tham gia nhom) - Auto Fixed",
    "description": "Jira Task SH-17: Đã sửa lỗi tự động lấy groupId và privateGroupId từ danh sách group thật.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "🔑 Đăng nhập Group Owner (user1) để tạo group test",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200 - Đăng nhập Group Owner (user1) thành công', () => pm.response.to.have.status(200));",
              "const json = pm.response.json();",
              "const resData = json.data || json;",
              "if (resData.access_token) {",
              "    pm.collectionVariables.set('accessToken', resData.access_token);",
              "    pm.collectionVariables.set('userId', resData.user && resData.user.id);",
              "}"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"user1@example.com\",\n  \"password\": \"11111111\"\n}"
        },
        "url": {
          "raw": "{{authBaseUrl}}/login",
          "host": [
            "{{authBaseUrl}}"
          ],
          "path": [
            "login"
          ]
        }
      }
    },
    {
      "name": "🧪 Tạo group PUBLIC dùng cho test join",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"SH-17 Public {{$timestamp}}\",\n  \"description\": \"Fixture group for join test\",\n  \"access\": \"PUBLIC\"\n}"
        },
        "url": {
          "raw": "{{groupBaseUrl}}",
          "host": [
            "{{groupBaseUrl}}"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 201 - Tạo group public thành công', () => pm.response.to.have.status(201));",
              "const json = pm.response.json();",
              "if (json.data?.id) pm.collectionVariables.set('groupId', json.data.id);"
            ]
          }
        }
      ]
    },
    {
      "name": "🧪 Tạo group RESTRICTED dùng cho test join request",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"SH-17 Restricted {{$timestamp}}\",\n  \"description\": \"Fixture group for join request test\",\n  \"access\": \"RESTRICTED\"\n}"
        },
        "url": {
          "raw": "{{groupBaseUrl}}",
          "host": [
            "{{groupBaseUrl}}"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 201 - Tạo group restricted thành công', () => pm.response.to.have.status(201));",
              "const json = pm.response.json();",
              "if (json.data?.id) pm.collectionVariables.set('privateGroupId', json.data.id);"
            ]
          }
        }
      ]
    },
    {
      "name": "🔑 Đăng nhập User thường (user8) (Lấy Access Token)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200 - Đăng nhập User thường (user8) thành công', () => pm.response.to.have.status(200));",
              "const json = pm.response.json();",
              "const resData = json.data || json;",
              "if (resData.access_token) {",
              "    pm.collectionVariables.set('accessToken', resData.access_token);",
              "    pm.collectionVariables.set('userId', resData.user && resData.user.id);",
              "}"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"user8@example.com\",\n  \"password\": \"11111111\"\n}"
        },
        "url": {
          "raw": "{{authBaseUrl}}/login",
          "host": [
            "{{authBaseUrl}}"
          ],
          "path": [
            "login"
          ]
        }
      }
    },
    {
      "name": "🔍 Lấy danh sách Group (Tự động lấy groupId & privateGroupId)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200 - Lấy danh sách group thành công', () => pm.response.to.have.status(200));",
              "const json = pm.response.json();",
              "const groups = json.data?.items || json.data || json;",
              "if (Array.isArray(groups)) {",
              "    const publicGroup = groups.find(g => g.access === 'PUBLIC' || g.type === 'PUBLIC' || g.isPrivate === false);",
              "    const privateGroup = groups.find(g => g.access === 'RESTRICTED' || g.access === 'PRIVATE' || g.type === 'RESTRICTED' || g.type === 'PRIVATE' || g.isPrivate === true);",
              "    if (publicGroup) pm.collectionVariables.set('groupId', publicGroup.id);",
              "    else if (groups.length > 0) pm.collectionVariables.set('groupId', groups[0].id);",
              "    if (privateGroup) pm.collectionVariables.set('privateGroupId', privateGroup.id);",
              "    else if (groups.length > 1) pm.collectionVariables.set('privateGroupId', groups[1].id);",
              "}"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}"
          }
        ],
        "url": {
          "raw": "{{groupBaseUrl}}",
          "host": [
            "{{groupBaseUrl}}"
          ]
        }
      }
    },
    {
      "name": "✅ Tham gia group PUBLIC (join - tự động vào ngay)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}"
          }
        ],
        "url": {
          "raw": "{{groupBaseUrl}}/{{groupId}}/join",
          "host": [
            "{{groupBaseUrl}}"
          ],
          "path": [
            "{{groupId}}",
            "join"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200', () => pm.response.to.have.status(200));"
            ]
          }
        }
      ]
    },
    {
      "name": "✅ Yêu cầu tham gia group PRIVATE (join - tạo join request chờ duyệt)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}"
          }
        ],
        "url": {
          "raw": "{{groupBaseUrl}}/{{privateGroupId}}/join",
          "host": [
            "{{groupBaseUrl}}"
          ],
          "path": [
            "{{privateGroupId}}",
            "join"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200', () => pm.response.to.have.status(200));",
              "const json = pm.response.json();",
              "if (json.data?.id) pm.collectionVariables.set('joinRequestId', json.data.id);"
            ]
          }
        }
      ]
    },
    {
      "name": "❌ Tham gia group đã là member rồi",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}"
          }
        ],
        "url": {
          "raw": "{{groupBaseUrl}}/{{groupId}}/join",
          "host": [
            "{{groupBaseUrl}}"
          ],
          "path": [
            "{{groupId}}",
            "join"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 400', () => pm.response.to.have.status(400));"
            ]
          }
        }
      ]
    },
    {
      "name": "❌ Tham gia group không tồn tại",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}"
          }
        ],
        "url": {
          "raw": "{{groupBaseUrl}}/00000000-0000-0000-0000-000000000000/join",
          "host": [
            "{{groupBaseUrl}}"
          ],
          "path": [
            "00000000-0000-0000-0000-000000000000",
            "join"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 400', () => pm.expect([400]).to.include(pm.response.code));"
            ]
          }
        }
      ]
    }
  ],
