  "item": [
    {
      "name": "🔑 Đăng nhập User thường (Lấy Access Token)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status 200 - Đăng nhập thành công\", function () {",
              "    pm.response.to.have.status(200);",
              "    const json = pm.response.json();",
              "    const resData = json.data || json;",
              "    if(resData.accessToken || resData.access_token) {",
              "        pm.collectionVariables.set(\"accessToken\", resData.accessToken || resData.access_token);",
              "    }",
              "    if(resData.user && resData.user.id) {",
              "        pm.collectionVariables.set(\"userId\", resData.user.id);",
              "    }",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{userEmail}}\",\n  \"password\": \"{{password}}\"\n}"
        },
        "url": {
          "raw": "{{authBaseUrl}}/login",
          "host": [
            "{{authBaseUrl}}"
          ],
          "path": [
            "login"
          ]
        }
      }
    },
    {
      "name": "Setup: Dang nhap user khac",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 200 - Dang nhap user khac thanh cong', () => pm.response.to.have.status(200));",
              "const json = pm.response.json();",
              "const resData = json.data || json;",
              "pm.collectionVariables.set('anotherUserAccessToken', resData.accessToken || resData.access_token);",
              "if (resData.user && resData.user.id) pm.collectionVariables.set('anotherUserId', resData.user.id);"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"user2@example.com\",\n  \"password\": \"{{password}}\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{authBaseUrl}}/login",
          "host": [
            "{{authBaseUrl}}"
          ],
          "path": [
            "login"
          ]
        }
      }
    },
    {
      "name": "Setup: Tao social link cua user khac",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 200 - Tao social link user khac', () => pm.response.to.have.status(200));",
              "const json = pm.response.json();",
              "if (json && json.id) pm.collectionVariables.set('otherUserSocialLinkId', json.id);"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{anotherUserAccessToken}}",
            "type": "text"
          },
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"url\": \"https://github.com/user2-guard\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{userBaseUrl}}/profile/{{anotherUserId}}/social",
          "host": [
            "{{userBaseUrl}}"
          ],
          "path": [
            "profile",
            "{{anotherUserId}}",
            "social"
          ]
        }
      }
    },
    {
      "name": "✅ Thêm social link",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "{{userBaseUrl}}/profile/{{userId}}/social",
          "host": [
            "{{userBaseUrl}}"
          ],
          "path": [
            "profile",
            "{{userId}}",
            "social"
          ]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"url\": \"https://github.com/nguyenvana\"\n}"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200', () => pm.response.to.have.status(200));",
              "const json = pm.response.json();",
              "if (json?.id) pm.collectionVariables.set('socialLinkId', json.id);"
            ]
          }
        }
      ]
    },
    {
      "name": "❌ Thêm social link - URL không hợp lệ",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "{{userBaseUrl}}/profile/{{userId}}/social",
          "host": [
            "{{userBaseUrl}}"
          ],
          "path": [
            "profile",
            "{{userId}}",
            "social"
          ]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"url\": \"not-a-valid-url\"\n}"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 400', () => pm.response.to.have.status(400));"
            ]
          }
        }
      ]
    },
    {
      "name": "✅ Xóa social link",
      "request": {
        "method": "DELETE",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}"
          }
        ],
        "url": {
          "raw": "{{userBaseUrl}}/profile/social/{{socialLinkId}}",
          "host": [
            "{{userBaseUrl}}"
          ],
          "path": [
            "profile",
            "social",
            "{{socialLinkId}}"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200', () => pm.response.to.have.status(200));"
            ]
          }
        }
      ]
    },
    {
      "name": "❌ Xóa social link - id không tồn tại",
      "request": {
        "method": "DELETE",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}"
          }
        ],
        "url": {
          "raw": "{{userBaseUrl}}/profile/social/00000000-0000-0000-0000-000000000000",
          "host": [
            "{{userBaseUrl}}"
          ],
          "path": [
            "profile",
            "social",
            "00000000-0000-0000-0000-000000000000"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 400', () => pm.response.to.have.status(400));"
            ]
          }
        }
      ]
    },
    {
      "name": "❌ Xóa social link - thuộc về user khác - Bị từ chối",
      "request": {
        "method": "DELETE",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}"
          }
        ],
        "url": {
          "raw": "{{userBaseUrl}}/profile/social/{{otherUserSocialLinkId}}",
          "host": [
            "{{userBaseUrl}}"
          ],
          "path": [
            "profile",
            "social",
            "{{otherUserSocialLinkId}}"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 403', () => pm.response.to.have.status(403));"
            ]
          }
        }
      ]
    }
  ]
}
