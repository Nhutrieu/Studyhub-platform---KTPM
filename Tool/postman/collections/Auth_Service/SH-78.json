{
  "info": {
    "name": "SH-78 - Functional Testing for User Registration",
    "description": "Tach tu StudyHub Auth Service collection - Task SH-78: Functional Testing for User Registration",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "✅ Đăng ký tài khoản mới",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "{{authBaseUrl}}/register",
          "host": [
            "{{authBaseUrl}}"
          ],
          "path": [
            "register"
          ]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"user_name\": \"user_{{rand}}\",\n  \"email\": \"user_{{rand}}@mail.com\",\n  \"password\": \"Password@123\",\n  \"display_name\": \"Nguyen Van A\"\n}"
        }
      },
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "const ts = Date.now();",
              "pm.collectionVariables.set('rand', ts);"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 201', () => pm.response.to.have.status(201));",
              "",
              "const json = pm.response.json();",
              "",
              "pm.test('Có user và verificationToken', () => {",
              "    pm.expect(json).to.have.property('user');",
              "    pm.expect(json).to.have.property('verificationToken');",
              "});",
              "",
              "if (json.verificationToken) pm.collectionVariables.set('verificationToken', json.verificationToken);",
              "if (json.user?.id) pm.collectionVariables.set('userId', json.user.id);",
              "",
              "console.log(pm.response.text());"
            ]
          }
        }
      ]
    },
