  },
  "item": [
    {
      "name": "✅ Đăng ký tài khoản mới",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "{{authBaseUrl}}/register",
          "host": [
            "{{authBaseUrl}}"
          ],
          "path": [
            "register"
          ]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"user_name\": \"{{regUsername}}\",\n  \"email\": \"{{regEmail}}\",\n  \"password\": \"Password@123\",\n  \"display_name\": \"Nguyen Van A\"\n}"
        }
      },
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "const rand = Math.floor(Math.random() * 10000000);",
              "pm.collectionVariables.set('regUsername', 'user_' + rand);",
              "pm.collectionVariables.set('regEmail', 'user_' + rand + '@example.com');"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 201', () => pm.response.to.have.status(201));",
              "const json = pm.response.json();",
              "pm.test('Có user và verificationToken', () => { pm.expect(json).to.have.property('user'); pm.expect(json).to.have.property('verificationToken'); });",
              "if (json.verificationToken) pm.collectionVariables.set('verificationToken', json.verificationToken);",
              "if (json.user?.id) pm.collectionVariables.set('userId', json.user.id);"
            ]
          }
        }
      ]
    },
