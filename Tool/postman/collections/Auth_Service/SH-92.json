{
  "info": {
    "name": "SH-92: Admin - Block / Unblock",
    "_postman_id": "47c1a346-6869-4825-95be-68443263974e",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "🔑 Admin Login (Pre-requisite)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"user_name\": \"admin\",\n  \"password\": \"11111111\"\n}"
        },
        "url": {
          "raw": "{{authBaseUrl}}/login",
          "host": [
            "{{authBaseUrl}}"
          ],
          "path": [
            "login"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200 (Admin Login)', () => pm.response.to.have.status(200));",
              "const json = pm.response.json();",
              "const target = json.data || json;",
              "if (target.access_token) pm.collectionVariables.set('adminAccessToken', target.access_token);"
            ]
          }
        }
      ]
    },
    {
      "name": "🔑 User Login for 403 Test (Pre-requisite)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"user1@example.com\",\n  \"password\": \"11111111\"\n}"
        },
        "url": {
          "raw": "{{authBaseUrl}}/login",
          "host": [
            "{{authBaseUrl}}"
          ],
          "path": [
            "login"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200 (User Login)', () => pm.response.to.have.status(200));",
              "const json = pm.response.json();",
              "const target = json.data || json;",
              "if (target.access_token) pm.collectionVariables.set('accessToken', target.access_token);"
            ]
          }
        }
      ]
    },
    {
      "name": "👥 Admin Get Users (Pre-requisite)",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{adminAccessToken}}"
          }
        ],
        "url": {
          "raw": "{{authBaseUrl}}/admin/users",
          "host": [
            "{{authBaseUrl}}"
          ],
          "path": [
            "admin",
            "users"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200 (Get Users)', () => pm.response.to.have.status(200));",
              "const json = pm.response.json();",
              "const target = json.data || json;",
              "if (Array.isArray(target)) {",
              "  const normalUser = target.find(u => u.user_name === 'user2' || u.user_name === 'user3');",
              "  if (normalUser) {",
              "    pm.collectionVariables.set('userId', normalUser.id);",
              "    pm.collectionVariables.set('deletableUserId', normalUser.id);",
              "  }",
              "}"
            ]
          }
        }
      ]
    },
    {
      "name": "⚠️ BUG THẬT: POST /users/:id/block bị định nghĩa 2 lần (permanent đè lên temporary)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{adminAccessToken}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "{{authBaseUrl}}/admin/users/{{userId}}/block",
          "host": [
            "{{authBaseUrl}}"
          ],
          "path": [
            "admin",
            "users",
            "{{userId}}",
            "block"
          ]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"reason\": \"Vi phạm điều khoản sử dụng\"\n}"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "// adminRoutes.js đăng ký router.post('/users/:user_id/block', ...) HAI LẦN với 2 controller khác nhau.",
              "// Express chỉ thực thi route khớp ĐẦU TIÊN (permanentBlockUser).",
              "// => temporaryBlockUser (route thứ 2, dùng blocked_until) KHÔNG BAO GIỜ được gọi qua path này, dù code định nghĩa.",
              "// Khuyến nghị fix: tách 2 path khác nhau, ví dụ POST /block và POST /block/temporary.",
              "pm.test('Status 200 (request chạy nhưng luôn là logic block vĩnh viễn)', () => pm.response.to.have.status(200));"
            ]
          }
        }
      ]
    },
    {
      "name": "⚠️ BUG THẬT: gửi blocked_until cũng không có tác dụng do bug route trùng path",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{adminAccessToken}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "{{authBaseUrl}}/admin/users/{{userId}}/block",
          "host": [
            "{{authBaseUrl}}"
          ],
          "path": [
            "admin",
            "users",
            "{{userId}}",
            "block"
          ]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"reason\": \"Vi phạm tạm thời\",\n  \"blocked_until\": \"2026-12-31T23:59:59.000Z\"\n}"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "// blocked_until sẽ bị bỏ qua hoàn toàn vì permanentBlockUser (route đầu tiên) không đọc field này.",
              "pm.test('Status 200 nhưng KHÔNG đúng nghiệp vụ block tạm thời', () => pm.response.to.have.status(200));"
            ]
          }
        }
      ]
    },
    {
