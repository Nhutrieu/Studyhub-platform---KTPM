{
  "info": {
    "name": "SH-86: Get Current User Info (Me)",
    "_postman_id": "07e034b4-d2ca-401f-82ec-7da3d3442011",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "🔑 Register Unique User (Pre-requisite)",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "const rand = Math.floor(Math.random() * 10000000);",
              "pm.collectionVariables.set('regUsername', 'user_' + rand);",
              "pm.collectionVariables.set('regEmail', 'user_' + rand + '@example.com');"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 201 (Register)', () => pm.response.to.have.status(201));",
              "const json = pm.response.json();",
              "const target = json.data || json;",
              "if (target.verificationToken) pm.collectionVariables.set('verificationToken', target.verificationToken);",
              "if (target.user && target.user.id) pm.collectionVariables.set('userId', target.user.id);"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"user_name\": \"{{regUsername}}\",\n  \"email\": \"{{regEmail}}\",\n  \"password\": \"Password@123\",\n  \"display_name\": \"Test User\"\n}"
        },
        "url": {
          "raw": "{{authBaseUrl}}/register",
          "host": [
            "{{authBaseUrl}}"
          ],
          "path": [
            "register"
          ]
        }
      }
    },
    {
      "name": "🔑 Verify User Email (Pre-requisite)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "{{authBaseUrl}}/verify-email?token={{verificationToken}}",
          "host": [
            "{{authBaseUrl}}"
          ],
          "path": [
            "verify-email"
          ],
          "query": [
            {
              "key": "token",
              "value": "{{verificationToken}}"
            }
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200 (Verify)', () => pm.response.to.have.status(200));"
            ]
          }
        }
      ]
    },
    {
      "name": "🔑 User Login (Pre-requisite)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{regEmail}}\",\n  \"password\": \"Password@123\"\n}"
        },
        "url": {
          "raw": "{{authBaseUrl}}/login",
          "host": [
            "{{authBaseUrl}}"
          ],
          "path": [
            "login"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200 (Login)', () => pm.response.to.have.status(200));",
              "const json = pm.response.json();",
              "const target = json.data || json;",
              "if (target.access_token) pm.collectionVariables.set('accessToken', target.access_token);",
              "if (target.refresh_token) pm.collectionVariables.set('refreshToken', target.refresh_token);"
            ]
          }
        }
      ]
    },
    {
      "name": "✅ Lấy thông tin user đang đăng nhập (me)",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}"
          }
        ],
        "url": {
          "raw": "{{authBaseUrl}}/me",
          "host": [
            "{{authBaseUrl}}"
          ],
          "path": [
            "me"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200', () => pm.response.to.have.status(200));",
              "pm.test('Có field user', () => pm.expect(pm.response.json()).to.have.property('user'));"
            ]
          }
        }
      ]
    },
    {
      "name": "❌ Lấy thông tin user - không có token",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{authBaseUrl}}/me",
          "host": [
            "{{authBaseUrl}}"
          ],
          "path": [
            "me"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 401', () => pm.response.to.have.status(401));"
            ]
          }
        }
      ]
    }
  ],
