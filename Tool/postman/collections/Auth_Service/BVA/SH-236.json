{
  "info": {
    "name": "StudyHub - SH-236 - BVA Đăng nhập",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "✅ Hợp lệ Biên Min user_name",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"user_name\": \"usr\",\n  \"password\": \"11111111\"\n}"
        },
        "url": {
          "raw": "{{authBaseUrl}}/login",
          "host": [
            "{{authBaseUrl}}"
          ],
          "path": [
            "login"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200 or 401', () => {",
              "  pm.expect(pm.response.code).to.be.oneOf([200, 401]);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "❌ Không hợp lệ dưới Min password (password < 8)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"user_name\": \"user1\",\n  \"password\": \"1234567\"\n}"
        },
        "url": {
          "raw": "{{authBaseUrl}}/login",
          "host": [
            "{{authBaseUrl}}"
          ],
          "path": [
            "login"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 401 or 400', () => {",
              "  pm.expect(pm.response.code).to.be.oneOf([401, 400]);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "❌ Không hợp lệ vượt Max password (password > 50)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"user_name\": \"user1\",\n  \"password\": \"ppppppppppppppppppppppppppppppppppppppppppppppppppp\"\n}"
        },
        "url": {
          "raw": "{{authBaseUrl}}/login",
          "host": [
            "{{authBaseUrl}}"
          ],
          "path": [
            "login"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 401 or 400', () => {",
              "  pm.expect(pm.response.code).to.be.oneOf([401, 400]);",
              "});"
            ]
          }
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "authBaseUrl",
      "value": "http://localhost:3000/api/v1/auth",
      "type": "string"
    },
    {
      "key": "accessToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "userId",
      "value": "",
      "type": "string"
    }
  ]
}