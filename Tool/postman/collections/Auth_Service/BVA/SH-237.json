{
  "info": {
    "name": "StudyHub - SH-237 - BVA Đổi mật khẩu",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "🔑 User Login (Pre-requisite)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"user_name\": \"user1\",\n  \"password\": \"11111111\"\n}"
        },
        "url": {
          "raw": "{{authBaseUrl}}/login",
          "host": [
            "{{authBaseUrl}}"
          ],
          "path": [
            "login"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const json = pm.response.json();",
              "const target = json.data || json;",
              "if (target.access_token) pm.collectionVariables.set('accessToken', target.access_token);",
              "if (target.user && target.user.id) pm.collectionVariables.set('userId', target.user.id);"
            ]
          }
        }
      ]
    },
    {
      "name": "✅ Hợp lệ Biên Min new_password (8 ký tự)",
      "request": {
        "method": "PUT",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"old_password\": \"11111111\",\n  \"new_password\": \"88888888\"\n}"
        },
        "url": {
          "raw": "{{authBaseUrl}}/change-password",
          "host": [
            "{{authBaseUrl}}"
          ],
          "path": [
            "change-password"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200 or 400', () => {",
              "  pm.expect(pm.response.code).to.be.oneOf([200, 400]);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "❌ Không hợp lệ dưới Min new_password (7 ký tự)",
      "request": {
        "method": "PUT",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"old_password\": \"11111111\",\n  \"new_password\": \"7777777\"\n}"
        },
        "url": {
          "raw": "{{authBaseUrl}}/change-password",
          "host": [
            "{{authBaseUrl}}"
          ],
          "path": [
            "change-password"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 400', () => pm.response.to.have.status(400));"
            ]
          }
        }
      ]
    },
    {
      "name": "❌ Không hợp lệ vượt Max new_password (51 ký tự)",
      "request": {
        "method": "PUT",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"old_password\": \"11111111\",\n  \"new_password\": \"ppppppppppppppppppppppppppppppppppppppppppppppppppp\"\n}"
        },
        "url": {
          "raw": "{{authBaseUrl}}/change-password",
          "host": [
            "{{authBaseUrl}}"
          ],
          "path": [
            "change-password"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 400', () => pm.response.to.have.status(400));"
            ]
          }
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "authBaseUrl",
      "value": "http://localhost:3000/api/v1/auth",
      "type": "string"
    },
    {
      "key": "accessToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "userId",
      "value": "",
      "type": "string"
    }
  ]
}