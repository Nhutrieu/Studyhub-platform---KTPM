{
  "info": {
    "name": "StudyHub - SH-235 - BVA Đăng ký tài khoản",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "✅ Hợp lệ Biên Min",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"user_name\": \"{{minUsername}}\",\n  \"password\": \"11111111\",\n  \"email\": \"{{minEmail}}\"\n}"
        },
        "url": {
          "raw": "{{authBaseUrl}}/register",
          "host": [
            "{{authBaseUrl}}"
          ],
          "path": [
            "register"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 201', () => pm.response.to.have.status(201));"
            ]
          }
        },
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "const randLetter = () => String.fromCharCode(97 + Math.floor(Math.random() * 26));",
              "const randStr = (len) => Array.from({length: len}, randLetter).join('');",
              "pm.collectionVariables.set('minUsername', randStr(3));",
              "pm.collectionVariables.set('minEmail', `${randLetter()}@${randLetter()}.${randLetter()}`);"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
