        "url": {
          "raw": "{{authBaseUrl}}/register",
          "host": [
            "{{authBaseUrl}}"
          ],
          "path": [
            "register"
          ]
        }
      }
    },
    {
      "name": "🔑 Register Blocked User (Pre-requisite)",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "const rand = Math.floor(Math.random() * 10000000);",
              "pm.collectionVariables.set('blockedUsername', 'user_' + rand);",
              "pm.collectionVariables.set('blockedEmail', 'user_' + rand + '@example.com');"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 201 (Register Blocked User)', () => pm.response.to.have.status(201));",
              "const json = pm.response.json();",
              "const target = json.data || json;",
              "if (target.verificationToken) pm.collectionVariables.set('blockedVerificationToken', target.verificationToken);",
              "if (target.user && target.user.id) pm.collectionVariables.set('blockedUserId', target.user.id);"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"user_name\": \"{{blockedUsername}}\",\n  \"email\": \"{{blockedEmail}}\",\n  \"password\": \"Password@123\",\n  \"display_name\": \"Blocked User\"\n}"
        },
        "url": {
          "raw": "{{authBaseUrl}}/register",
          "host": [
            "{{authBaseUrl}}"
          ],
          "path": [
            "register"
          ]
        }
      }
    },
    {
