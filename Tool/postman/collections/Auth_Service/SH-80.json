        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200 (Verify Blocked User)', () => pm.response.to.have.status(200));"
            ]
          }
        }
      ]
    },
    {
      "name": "🔑 Admin Login (Pre-requisite)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"user_name\": \"admin\",\n  \"password\": \"11111111\"\n}"
        },
        "url": {
          "raw": "{{authBaseUrl}}/login",
          "host": [
            "{{authBaseUrl}}"
          ],
          "path": [
            "login"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const json = pm.response.json();",
              "const target = json.data || json;",
              "if (target.access_token) pm.collectionVariables.set('adminAccessToken', target.access_token);"
            ]
          }
        }
      ]
    },
    {
      "name": "🔑 Lock Blocked User (Pre-requisite)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{adminAccessToken}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"reason\": \"testing block user\"\n}"
        },
        "url": {
          "raw": "{{authBaseUrl}}/admin/users/{{blockedUserId}}/lock",
          "host": [
            "{{authBaseUrl}}"
          ],
          "path": [
            "admin",
            "users",
            "{{blockedUserId}}",
            "lock"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200 (Lock Blocked User)', () => pm.response.to.have.status(200));"
            ]
          }
        }
      ]
    },
    {
      "name": "✅ Đăng nhập bằng email",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "{{authBaseUrl}}/login",
          "host": [
            "{{authBaseUrl}}"
          ],
          "path": [
            "login"
          ]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{loginEmail}}\",\n  \"password\": \"Password@123\"\n}"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200', () => pm.response.to.have.status(200));",
              "const json = pm.response.json();",
              "pm.test('Có access_token và refresh_token', () => { pm.expect(json).to.have.property('access_token'); pm.expect(json).to.have.property('refresh_token'); });",
              "if (json.access_token) pm.collectionVariables.set('accessToken', json.access_token);",
              "if (json.refresh_token) pm.collectionVariables.set('refreshToken', json.refresh_token);",
              "if (json.user?.id) pm.collectionVariables.set('userId', json.user.id);"
            ]
          }
        }
      ]
    },
