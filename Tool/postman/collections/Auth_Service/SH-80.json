  "item": [
    {
      "name": "🔑 Register Login User (Pre-requisite)",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "const rand = Math.floor(Math.random() * 10000000);",
              "pm.collectionVariables.set('loginUsername', 'user_' + rand);",
              "pm.collectionVariables.set('loginEmail', 'user_' + rand + '@example.com');"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 201 (Register Login User)', () => pm.response.to.have.status(201));",
              "const json = pm.response.json();",
              "const target = json.data || json;",
              "if (target.verificationToken) pm.collectionVariables.set('loginVerificationToken', target.verificationToken);"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"user_name\": \"{{loginUsername}}\",\n  \"email\": \"{{loginEmail}}\",\n  \"password\": \"Password@123\",\n  \"display_name\": \"Login User\"\n}"
        },
        "url": {
          "raw": "{{authBaseUrl}}/register",
          "host": [
            "{{authBaseUrl}}"
          ],
          "path": [
            "register"
          ]
        }
      }
    },
    {
      "name": "🔑 Verify Login User (Pre-requisite)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "{{authBaseUrl}}/verify-email?token={{loginVerificationToken}}",
          "host": [
            "{{authBaseUrl}}"
          ],
          "path": [
            "verify-email"
          ],
          "query": [
            {
              "key": "token",
              "value": "{{loginVerificationToken}}"
            }
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200 (Verify Login User)', () => pm.response.to.have.status(200));"
            ]
          }
        }
      ]
    },
    {
