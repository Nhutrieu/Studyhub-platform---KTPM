{
  "info": {
    "name": "StudyHub - SH-144 - Kiểm thử xóa 1 thông báo (BVA)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "authBaseUrl",
      "value": "http://localhost:8000/api/v1/auth"
    },
    {
      "key": "notificationBaseUrl",
      "value": "http://localhost:8000/api/v1/notification"
    },
    {
      "key": "gatewayUrl",
      "value": "http://localhost:8000/api/v1"
    },
    {
      "key": "userEmail",
      "value": "user1@example.com"
    },
    {
      "key": "adminEmail",
      "value": "admin@example.com"
    },
    {
      "key": "password",
      "value": "11111111"
    }
  ],
  "item": [
    {
      "name": "🔑 Đăng nhập User thường (Lấy Access Token)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status 200 - Đăng nhập thành công\", function () {",
              "    pm.response.to.have.status(200);",
              "    const json = pm.response.json();",
              "    const resData = json.data || json;",
              "    if(resData.accessToken || resData.access_token) {",
              "        pm.collectionVariables.set(\"accessToken\", resData.accessToken || resData.access_token);",
              "    }",
              "    if(resData.user && resData.user.id) {",
              "        pm.collectionVariables.set(\"userId\", resData.user.id);",
              "    }",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{userEmail}}\",\n  \"password\": \"{{password}}\"\n}"
        },
        "url": {
          "raw": "{{authBaseUrl}}/login",
          "host": [
            "{{authBaseUrl}}"
          ],
          "path": [
            "login"
          ]
        }
      }
    },
    {
      "name": "🛠️ Dynamic Seeding (Tạo Notification Mồi)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status 201\", () => pm.response.to.have.status(201));"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\"sender_id\":\"5f8d0d55b54764421b7156d0\",\"content\":\"Dynamic test message\",\"receiver_ids\":[\"{{userId}}\"],\"type\":\"TEST\",\"target\":{\"type\":\"post\",\"id\":\"123456789012345678901234\"}}"
        },
        "url": {
          "raw": "{{notificationBaseUrl}}/",
          "host": [
            "{{notificationBaseUrl}}"
          ],
          "path": [
            ""
          ]
        }
      }
    },
    {
      "name": "🔍 Lấy receiver_entry_id của notification vừa tạo",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status 200 - Lấy danh sách thành công\", () => pm.response.to.have.status(200));",
              "const json = pm.response.json();",
              "const list = json.data || json;",
              "if(list && list.length > 0) {",
              "    pm.collectionVariables.set(\"dynamicNotifId\", list[0].id);",
              "}"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}"
          }
        ],
        "url": {
          "raw": "{{notificationBaseUrl}}/?limit=1&offset=0",
          "host": [
            "{{notificationBaseUrl}}"
          ],
          "path": [
            ""
          ],
          "query": [
            {
              "key": "limit",
              "value": "1"
            },
            {
              "key": "offset",
              "value": "0"
            }
          ]
        }
      }
    },
    {
      "name": "✅ Hợp lệ ID chuẩn (24 char)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status 200\", () => pm.expect(pm.response.code).to.be.oneOf([200, 204]));"
            ]
          }
        }
      ],
      "request": {
        "method": "DELETE",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}"
          }
        ],
        "url": {
          "raw": "{{notificationBaseUrl}}/{{dynamicNotifId}}",
          "host": [
            "{{notificationBaseUrl}}"
          ],
          "path": [
            "{{dynamicNotifId}}"
          ]
        }
      }
    },
    {
      "name": "❌ Không hợp lệ ID ngắn (23 char)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status 400/404\", () => pm.expect(pm.response.code).to.be.oneOf([400,404]));"
            ]
          }
        }
      ],
      "request": {
        "method": "DELETE",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}"
          }
        ],
        "url": {
          "raw": "{{notificationBaseUrl}}/12345678901234567890123",
          "host": [
            "{{notificationBaseUrl}}"
          ],
          "path": [
            "12345678901234567890123"
          ]
        }
      }
    },
    {
      "name": "❌ Không hợp lệ ID dài (25 char)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status 400/404\", () => pm.expect(pm.response.code).to.be.oneOf([400,404]));"
            ]
          }
        }
      ],
      "request": {
        "method": "DELETE",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}"
          }
        ],
        "url": {
          "raw": "{{notificationBaseUrl}}/1234567890123456789012345",
          "host": [
            "{{notificationBaseUrl}}"
          ],
          "path": [
            "1234567890123456789012345"
          ]
        }
      }
    }
  ]
}