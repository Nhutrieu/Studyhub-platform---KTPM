{
  "info": {
    "name": "StudyHub - SH-33 - Kiểm thử chức năng lấy danh sách thông báo",
    "description": "Postman collection for task SH-33: Kiểm thử chức năng lấy danh sách thông báo",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "🔔 [notification-service:3005] Notification (/)",
      "item": [
        {
          "name": "🔑 Đăng nhập User thường (Lấy Access Token)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200 - Đăng nhập User thành công', () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "const resData = json.data || json;",
                  "if (resData.access_token) {",
                  "    pm.collectionVariables.set('accessToken', resData.access_token);",
                  "    pm.collectionVariables.set('userId', resData.user && resData.user.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{userEmail}}\",\n  \"password\": \"{{password}}\"\n}"
            },
            "url": {
              "raw": "{{authBaseUrl}}/login",
              "host": [
                "{{authBaseUrl}}"
              ],
              "path": [
                "login"
              ]
            }
          }
        },
        {
          "name": "✅ Lấy danh sách thông báo của tôi",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "{{notificationBaseUrl}}/?limit=50&offset=0",
              "host": [
                "{{notificationBaseUrl}}"
              ],
              "path": [
                ""
              ],
              "query": [
                {
                  "key": "limit",
                  "value": "50"
                },
                {
                  "key": "offset",
                  "value": "0"
                }
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "pm.test('Có field success và data', () => { pm.expect(json).to.have.property('success'); pm.expect(json).to.have.property('data'); });"
                ]
              }
            }
          ]
        },
        {
          "name": "✅ Lọc thông báo theo status (unread)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "{{notificationBaseUrl}}/?status=unread&limit=20",
              "host": [
                "{{notificationBaseUrl}}"
              ],
              "path": [
                ""
              ],
              "query": [
                {
                  "key": "status",
                  "value": "unread"
                },
                {
                  "key": "limit",
                  "value": "20"
                }
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));"
                ]
              }
            }
          ]
        },
        {
          "name": "❌ Lấy danh sách thông báo - không có token",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{notificationBaseUrl}}/",
              "host": [
                "{{notificationBaseUrl}}"
              ],
              "path": [
                ""
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 401', () => pm.response.to.have.status(401));"
                ]
              }
            }
          ]
        }
      ]
    }
  ],
