{
  "info": {
    "name": "StudyHub - SH-37 - Kiểm thử chức năng đánh dấu một thông báo đã đọc",
    "description": "Postman collection for task SH-37: Kiểm thử chức năng đánh dấu một thông báo đã đọc",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "🔔 [notification-service:3005] Notification (/)",
      "item": [
        {
          "name": "🔑 Đăng nhập User thường (Lấy Access Token)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200 - Đăng nhập User thành công', () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "const resData = json.data || json;",
                  "if (resData.access_token) {",
                  "    pm.collectionVariables.set('accessToken', resData.access_token);",
                  "    pm.collectionVariables.set('userId', resData.user && resData.user.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{userEmail}}\",\n  \"password\": \"{{password}}\"\n}"
            },
            "url": {
              "raw": "{{authBaseUrl}}/login",
              "host": [
                "{{authBaseUrl}}"
              ],
              "path": [
                "login"
              ]
            }
          }
        },
        {
          "name": "🔑 Đăng nhập Admin (Lấy Admin Access Token)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200 - Đăng nhập Admin thành công', () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "const resData = json.data || json;",
                  "if (resData.access_token) {",
                  "    pm.collectionVariables.set('adminAccessToken', resData.access_token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{adminEmail}}\",\n  \"password\": \"{{password}}\"\n}"
            },
            "url": {
              "raw": "{{authBaseUrl}}/login",
              "host": [
                "{{authBaseUrl}}"
              ],
              "path": [
                "login"
              ]
            }
          }
        },
        {
          "name": "✅ Tạo thông báo mồi (Setup Data)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{adminAccessToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{notificationBaseUrl}}/",
              "host": [
                "{{notificationBaseUrl}}"
              ],
              "path": [
                ""
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"sender_id\": \"{{userId}}\",\n  \"content\": \"Tài liệu của bạn đã được duyệt!\",\n  \"target\": {\n    \"type\": \"document\",\n    \"id\": \"5f8d0d55b54764421b7156d4\"\n  },\n  \"type\": \"document_approved\",\n  \"receiver_ids\": [\n    \"{{userId}}\"\n  ]\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Setup Data - Status 201', () => pm.response.to.have.status(201));",
                  "pm.sendRequest({",
                  "    url: pm.variables.replaceIn('{{notificationBaseUrl}}/'),",
                  "    method: 'GET',",
                  "    header: { 'Authorization': 'Bearer ' + pm.variables.get('accessToken') }",
                  "}, function (err, res) {",
                  "    if (!err) {",
                  "        const json = res.json();",
                  "        if (json.data && json.data.length > 0) {",
                  "            pm.collectionVariables.set('notificationId', json.data[0].id);",
                  "        }",
                  "    }",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "✅ Đánh dấu 1 thông báo đã đọc",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "{{notificationBaseUrl}}/{{notificationId}}/read",
              "host": [
                "{{notificationBaseUrl}}"
              ],
              "path": [
                "{{notificationId}}",
                "read"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));"
                ]
              }
            }
          ]
        },
        {
          "name": "❌ Đánh dấu đã đọc - thông báo không tồn tại",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "{{notificationBaseUrl}}/000000000000000000000000/read",
              "host": [
                "{{notificationBaseUrl}}"
              ],
              "path": [
                "000000000000000000000000",
                "read"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 404 hoặc 500', () => pm.expect([404, 500]).to.include(pm.response.code));"
                ]
              }
            }
          ]
        },
        {
          "name": "❌ Đánh dấu đã đọc thông báo của NGƯỜI KHÁC - Bị từ chối",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "{{notificationBaseUrl}}/5f8d0d55b54764421b7156d1/read",
              "host": [
                "{{notificationBaseUrl}}"
              ],
              "path": [
                "5f8d0d55b54764421b7156d1",
                "read"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 403 hoặc 404', () => pm.expect([403, 404]).to.include(pm.response.code));"
                ]
              }
            }
          ]
        }
      ]
    }
  ],
