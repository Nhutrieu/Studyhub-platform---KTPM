{
  "info": {
    "name": "SH-251: Boundary Admin Document Service",
    "description": "Boundary Value Analysis bổ sung cho SH-70. File gốc SH-70.json không bị sửa.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Login admin",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{adminEmail}}\",\n  \"password\": \"{{password}}\"\n}"
        },
        "url": "{{authBaseUrl}}/login"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Login 200', () => pm.response.to.have.status(200));",
              "var data = (pm.response.json().data || pm.response.json());",
              "pm.collectionVariables.set('adminAccessToken', data.access_token);"
            ]
          }
        }
      ]
    },
    {
      "name": "Login user thường",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{userEmail}}\",\n  \"password\": \"{{password}}\"\n}"
        },
        "url": "{{authBaseUrl}}/login"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Login 200', () => pm.response.to.have.status(200));",
              "var data = (pm.response.json().data || pm.response.json());",
              "pm.collectionVariables.set('accessToken', data.access_token);"
            ]
          }
        }
      ]
    },
    {
      "name": "BVA admin approved - admin valid",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{adminAccessToken}}" }
        ],
        "url": "{{documentBaseUrl}}/admin/approved"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 200', () => pm.response.to.have.status(200));"
            ]
          }
        }
      ]
    },
    {
      "name": "BVA admin approved - user thường forbidden",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{accessToken}}" }
        ],
        "url": "{{documentBaseUrl}}/admin/approved"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 403', () => pm.response.to.have.status(403));"
            ]
          }
        }
      ]
    },
    {
      "name": "BVA admin comments - limit min = 1",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{adminAccessToken}}" }
        ],
        "url": "{{documentBaseUrl}}/admin/comments?limit=1&offset=0"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 200', () => pm.response.to.have.status(200));"
            ]
          }
        }
      ]
    },
    {
      "name": "BVA admin comments - limit vượt 100 = 101",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{adminAccessToken}}" }
        ],
        "url": "{{documentBaseUrl}}/admin/comments?limit=101&offset=0"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 200', () => pm.response.to.have.status(200));",
              "var body = pm.response.json();",
              "var rows = Array.isArray(body) ? body : (body.data || body.comments || []);",
              "pm.test('Limit được cap <= 100 nếu response là array', () => pm.expect(rows.length).to.be.at.most(100));"
            ]
          }
        }
      ]
    },
    {
      "name": "BVA admin comments - offset âm = -1",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{adminAccessToken}}" }
        ],
        "url": "{{documentBaseUrl}}/admin/comments?limit=50&offset=-1"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 200 hoặc 500', () => pm.expect([200, 500]).to.include(pm.response.code));"
            ]
          }
        }
      ]
    },
    {
      "name": "BVA countDocuments - user thường forbidden",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{accessToken}}" }
        ],
        "url": "{{documentBaseUrl}}/admin/countDocuments"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 403', () => pm.response.to.have.status(403));"
            ]
          }
        }
      ]
    }
  ],
  "variable": [
    { "key": "authBaseUrl", "value": "http://localhost:3000/api/v1/auth" },
    {
      "key": "documentBaseUrl",
      "value": "http://localhost:3003/api/v1/document"
    },
    { "key": "adminEmail", "value": "admin@example.com" },
    { "key": "userEmail", "value": "user1@example.com" },
    { "key": "password", "value": "11111111" },
    { "key": "adminAccessToken", "value": "" },
    { "key": "accessToken", "value": "" }
  ]
}
