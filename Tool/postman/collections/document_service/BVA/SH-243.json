{
  "info": {
    "name": "SH-243: Boundary Upload Tài liệu",
    "description": "Boundary Value Analysis bổ sung cho SH-62. File gốc SH-62.json không bị sửa.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Login user thường",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{userEmail}}\",\n  \"password\": \"{{password}}\"\n}"
        },
        "url": "{{authBaseUrl}}/login"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Login 200', () => pm.response.to.have.status(200));",
              "var json = pm.response.json();",
              "var data = json.data || json;",
              "pm.collectionVariables.set('accessToken', data.access_token);"
            ]
          }
        }
      ]
    },
    {
      "name": "BVA upload - title min 1 ký tự",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{accessToken}}" }
        ],
        "body": {
          "mode": "formdata",
          "formdata": [
            { "key": "title", "value": "A" },
            { "key": "description", "value": "BVA title min length" },
            { "key": "visibility", "value": "PUBLIC" },
            { "key": "tags", "value": "bva,sh-62" },
            {
              "key": "file",
              "type": "file",
              "src": "Tool/postman/fixtures/document.pdf"
            }
          ]
        },
        "url": "{{documentBaseUrl}}/"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 200', () => pm.response.to.have.status(200));"
            ]
          }
        }
      ]
    },
    {
      "name": "BVA upload - title rỗng",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{accessToken}}" }
        ],
        "body": {
          "mode": "formdata",
          "formdata": [
            { "key": "title", "value": "" },
            { "key": "description", "value": "BVA empty title" },
            { "key": "visibility", "value": "PUBLIC" },
            {
              "key": "file",
              "type": "file",
              "src": "Tool/postman/fixtures/document.pdf"
            }
          ]
        },
        "url": "{{documentBaseUrl}}/"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 200 hoặc 400', () => pm.expect([200, 400]).to.include(pm.response.code));"
            ]
          }
        }
      ]
    },
    {
      "name": "BVA upload - visibility chữ thường public",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{accessToken}}" }
        ],
        "body": {
          "mode": "formdata",
          "formdata": [
            { "key": "title", "value": "BVA lowercase visibility" },
            {
              "key": "description",
              "value": "visibility public lower-case should be rejected by enum"
            },
            { "key": "visibility", "value": "public" },
            {
              "key": "file",
              "type": "file",
              "src": "Tool/postman/fixtures/document.pdf"
            }
          ]
        },
        "url": "{{documentBaseUrl}}/"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 200 hoặc 400', () => pm.expect([200, 400]).to.include(pm.response.code));"
            ]
          }
        }
      ]
    },
    {
      "name": "BVA upload - thiếu file",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{accessToken}}" }
        ],
        "body": {
          "mode": "formdata",
          "formdata": [
            { "key": "title", "value": "BVA missing file" },
            { "key": "visibility", "value": "PUBLIC" }
          ]
        },
        "url": "{{documentBaseUrl}}/"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 400', () => pm.response.to.have.status(400));"
            ]
          }
        }
      ]
    },
    {
      "name": "BVA upload - file quá 100MB + 1",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{accessToken}}" }
        ],
        "body": {
          "mode": "formdata",
          "formdata": [
            { "key": "title", "value": "BVA oversized file" },
            { "key": "visibility", "value": "PUBLIC" },
            {
              "key": "file",
              "type": "file",
              "src": "Tool/postman/fixtures/oversized-file-over-100mb.zip"
            }
          ]
        },
        "url": "{{documentBaseUrl}}/"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 400 hoặc 413', () => pm.expect([400, 413]).to.include(pm.response.code));"
            ]
          }
        }
      ]
    }
  ],
  "variable": [
    { "key": "authBaseUrl", "value": "http://localhost:3000/api/v1/auth" },
    {
      "key": "documentBaseUrl",
      "value": "http://localhost:3003/api/v1/document"
    },
    { "key": "userEmail", "value": "user1@example.com" },
    { "key": "password", "value": "11111111" },
    { "key": "accessToken", "value": "" }
  ]
}
