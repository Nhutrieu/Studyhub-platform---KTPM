{
  "info": {
    "name": "SH-244: Boundary Danh sách Tài liệu",
    "description": "Boundary Value Analysis bổ sung cho SH-63. File gốc SH-63.json không bị sửa.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Login user thường",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{userEmail}}\",\n  \"password\": \"{{password}}\"\n}"
        },
        "url": "{{authBaseUrl}}/login"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Login 200', () => pm.response.to.have.status(200));",
              "var data = (pm.response.json().data || pm.response.json());",
              "pm.collectionVariables.set('accessToken', data.access_token);",
              "if (data.user && data.user.id) pm.collectionVariables.set('userId', data.user.id);"
            ]
          }
        }
      ]
    },
    {
      "name": "Login group manager",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{groupManagerEmail}}\",\n  \"password\": \"{{password}}\"\n}"
        },
        "url": "{{authBaseUrl}}/login"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Login 200', () => pm.response.to.have.status(200));",
              "var data = (pm.response.json().data || pm.response.json());",
              "pm.collectionVariables.set('groupManagerNotOwnerToken', data.access_token);"
            ]
          }
        }
      ]
    },
    {
      "name": "BVA /me - có token",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{accessToken}}" }
        ],
        "url": "{{documentBaseUrl}}/me"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 200', () => pm.response.to.have.status(200));",
              "pm.test('Array response', () => pm.expect(pm.response.json()).to.be.an('array'));"
            ]
          }
        }
      ]
    },
    {
      "name": "BVA group approved - limit min = 1",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{accessToken}}" }
        ],
        "url": "{{documentBaseUrl}}/group/{{groupId}}/approved?limit=1&offset=0"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 200', () => pm.response.to.have.status(200));"
            ]
          }
        }
      ]
    },
    {
      "name": "BVA group approved - group_id sai format",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{accessToken}}" }
        ],
        "url": "{{documentBaseUrl}}/group/not-a-uuid/approved?limit=1&offset=0"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status lỗi', () => pm.expect([400, 403, 404]).to.include(pm.response.code));"
            ]
          }
        }
      ]
    },
    {
      "name": "BVA group pending - manager limit vượt 100",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{groupManagerNotOwnerToken}}"
          }
        ],
        "url": "{{documentBaseUrl}}/group/{{groupId}}/pending?limit=101&offset=0"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 200 hoặc 400', () => pm.expect([200, 400]).to.include(pm.response.code));"
            ]
          }
        }
      ]
    },
    {
      "name": "BVA user public - user_id nil UUID",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{accessToken}}" }
        ],
        "url": "{{documentBaseUrl}}/user/00000000-0000-0000-0000-000000000000/public"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 200 hoặc 404', () => pm.expect([200, 404]).to.include(pm.response.code));"
            ]
          }
        }
      ]
    }
  ],
  "variable": [
    { "key": "authBaseUrl", "value": "http://localhost:3000/api/v1/auth" },
    {
      "key": "documentBaseUrl",
      "value": "http://localhost:3003/api/v1/document"
    },
    { "key": "userEmail", "value": "user1@example.com" },
    { "key": "groupManagerEmail", "value": "user4@example.com" },
    { "key": "password", "value": "11111111" },
    { "key": "groupId", "value": "aaaaaaaa-aaaa-4aaa-8aaa-aaaaaaaaaaa1" },
    { "key": "accessToken", "value": "" },
    { "key": "groupManagerNotOwnerToken", "value": "" },
    { "key": "userId", "value": "" }
  ]
}
