        {
          "name": "🔧 [Setup] user1 upload doc vào Group Alpha để tạo PENDING doc (lưu pendingDocumentId)",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "// Cần file thật để upload. Nếu chạy Newman tự động, thay '/path/to/document.pdf'",
                  "// bằng đường dẫn tuyệt đối đến file PDF/PPTX/DOCX thật trên máy."
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const json = pm.response.json();",
                  "    const res = json.data || json;",
                  "    if (res && res.id) {",
                  "        pm.collectionVariables.set('pendingDocumentId', res.id);",
                  "        console.log('pendingDocumentId set to:', res.id);",
                  "    }",
                  "} else {",
                  "    console.warn('Upload failed, pendingDocumentId not updated. Status:', pm.response.code);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "file",
                  "type": "file",
                  "src": "Tool/postman/fixtures/document.pdf"
                },
                {
                  "key": "title",
                  "value": "Setup Pending Doc 1 for Approve Test",
                  "type": "text"
                },
                {
                  "key": "visibility",
                  "value": "GROUP",
                  "type": "text"
                },
                {
                  "key": "group_id",
                  "value": "{{groupId}}",
                  "type": "text"
                }
              ]
            },
            "url": {
              "raw": "{{documentBaseUrl}}/",
              "host": ["{{documentBaseUrl}}"],
              "path": [""]
            }
          }
        },
        {
          "name": "🔧 [Setup] user3 upload doc vào Group Alpha để tạo PENDING doc (lưu pendingDocumentId2)",
          "event": [
