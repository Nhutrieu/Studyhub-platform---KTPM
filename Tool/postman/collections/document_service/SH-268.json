            "url": {
              "raw": "{{documentBaseUrl}}/interactions/{{pendingDocumentId}}/approve",
              "host": ["{{documentBaseUrl}}"],
              "path": ["interactions", "{{pendingDocumentId}}", "approve"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"group_id\": \"{{groupId}}\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));"
                ]
              }
            }
          ]
        },
        {
          "name": "❌ [Member thường] Duyệt tài liệu - Bị từ chối",
