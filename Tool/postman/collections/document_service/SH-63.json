{
  "info": {
    "name": "SH-63: Kiểm thử Chức năng Xem Danh sách Tài liệu",
    "description": "StudyHub Document Service - SH-63: Kiểm thử Chức năng Xem Danh sách Tài liệu",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "📄 [document-service:3003] Document (/)",
      "item": [
        {
          "name": "🔑 Đăng nhập User thường (Lấy accessToken)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200 - Đăng nhập thành công', () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "const resData = json.data || json;",
                  "if (resData.access_token) {",
                  "    pm.collectionVariables.set('accessToken', resData.access_token);",
                  "    pm.collectionVariables.set('userId', resData.user && resData.user.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{userEmail}}\",\n  \"password\": \"{{password}}\"\n}"
            },
            "url": {
              "raw": "{{authBaseUrl}}/login",
              "host": [
                "{{authBaseUrl}}"
              ],
              "path": [
                "login"
              ]
            }
          }
        },
        {
          "name": "🔑 Đăng nhập Group Owner (Lấy groupOwnerToken)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200 - Đăng nhập thành công', () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "const resData = json.data || json;",
                  "if (resData.access_token) {",
                  "    pm.collectionVariables.set('groupOwnerToken', resData.access_token);",
                  "    pm.collectionVariables.set('groupOwnerUserId', resData.user && resData.user.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
