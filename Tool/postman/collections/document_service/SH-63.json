        },
        {
          "name": "🔑 Đăng nhập Another User (user2 - Lấy anotherUserAccessToken)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200 - Đăng nhập thành công', () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
