            },
            "url": {
              "raw": "{{authBaseUrl}}/login",
              "host": [
                "{{authBaseUrl}}"
              ],
              "path": [
                "login"
              ]
            }
          }
        },
        {
          "name": "🔑 Đăng nhập Group Manager/Moderator (user4 - Lấy groupManagerNotOwnerToken)",
          "event": [
            {
              "listen": "test",
