              ]
            }
          }
        },
        {
          "name": "✅ Lấy danh sách tài liệu của tôi (me)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "{{documentBaseUrl}}/me",
              "host": [
                "{{documentBaseUrl}}"
              ],
              "path": [
                "me"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));"
                ]
              }
            }
          ]
        },
        {
          "name": "✅ [Member Group] Lấy danh sách tài liệu đã duyệt trong group",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{groupOwnerToken}}"
              }
            ],
            "url": {
              "raw": "{{documentBaseUrl}}/group/{{groupId}}/approved",
              "host": [
                "{{documentBaseUrl}}"
              ],
              "path": [
                "group",
                "{{groupId}}",
                "approved"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "// NOTE: Dùng groupOwnerToken (user3) vì user3 là member của Group Alpha (submitted doc vào group)"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "✅ [Owner/Manager Group] Lấy danh sách tài liệu đang chờ duyệt",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{groupOwnerToken}}"
              }
            ],
            "url": {
              "raw": "{{documentBaseUrl}}/group/{{groupId}}/pending",
              "host": [
                "{{documentBaseUrl}}"
              ],
              "path": [
                "group",
                "{{groupId}}",
                "pending"
              ]
            }
          },
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "// PRE-CONDITION: user3 phải là OWNER hoặc MODERATOR trong Group Alpha.",
                  "// Nếu group Alpha chưa tồn tại trong group_db, cần tạo qua API group service trước.",
                  "// groupOwnerToken = user3 token (đã login ở bước trên)"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "// Nếu 403: user3 chưa được assign role OWNER/MODERATOR trong group_db → cần setup group trước"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "❌ [Member thường] Lấy tài liệu pending của group - Bị từ chối",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "{{documentBaseUrl}}/group/{{groupId}}/pending",
              "host": [
                "{{documentBaseUrl}}"
              ],
              "path": [
                "group",
                "{{groupId}}",
                "pending"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 403', () => pm.response.to.have.status(403));"
                ]
              }
            }
          ]
        },
        {
          "name": "✅ Lấy tài liệu công khai trên trang cá nhân của 1 user",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "{{documentBaseUrl}}/user/{{userId}}/public",
              "host": [
                "{{documentBaseUrl}}"
              ],
              "path": [
                "user",
                "{{userId}}",
                "public"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));"
                ]
              }
            }
          ]
        }
      ]
    }
