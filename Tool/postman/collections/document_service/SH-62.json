{
  "info": {
    "name": "SH-62: Kiểm thử Chức năng Upload Tài liệu",
    "description": "StudyHub Document Service - SH-62: Kiểm thử Chức năng Upload Tài liệu",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "📄 [document-service:3003] Document (/)",
      "item": [
        {
          "name": "🔑 Đăng nhập User thường (Lấy accessToken)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200 - Đăng nhập thành công', () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "const resData = json.data || json;",
                  "if (resData.access_token) {",
                  "    pm.collectionVariables.set('accessToken', resData.access_token);",
                  "    pm.collectionVariables.set('userId', resData.user && resData.user.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{userEmail}}\",\n  \"password\": \"{{password}}\"\n}"
            },
            "url": {
              "raw": "{{authBaseUrl}}/login",
              "host": ["{{authBaseUrl}}"],
              "path": ["login"]
            }
          }
        },
        {
          "name": "🔑 Đăng nhập Outsider (Lấy outsiderToken)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200 - Đăng nhập thành công', () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "const resData = json.data || json;",
                  "if (resData.access_token) {",
                  "    pm.collectionVariables.set('outsiderToken', resData.access_token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{outsiderEmail}}\",\n  \"password\": \"{{password}}\"\n}"
            },
            "url": {
              "raw": "{{authBaseUrl}}/login",
              "host": ["{{authBaseUrl}}"],
              "path": ["login"]
            }
          }
        },
        {
          "name": "❌ Upload tài liệu mới - không có token",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{documentBaseUrl}}/",
              "host": ["{{documentBaseUrl}}"],
              "path": [""]
            },
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "title",
                  "value": "Bai giang Giai tich 1"
                }
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 401', () => pm.response.to.have.status(401));"
                ]
              }
            }
          ]
        },
        {
          "name": "✅ [MANUAL - cần file thật] Upload tài liệu mới (multipart, có file)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "{{documentBaseUrl}}/",
              "host": ["{{documentBaseUrl}}"],
              "path": [""]
            },
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "title",
                  "value": "Bai giang Giai tich 1 - Chuong 1"
                },
                {
                  "key": "description",
                  "value": "Tai lieu on tap chuong 1: gioi han va lien tuc"
                },
                {
                  "key": "visibility",
                  "value": "public"
                },
                {
                  "key": "tags",
                  "value": "toan,giai-tich,chuong1"
                },
                {
                  "key": "group_id",
                  "value": "{{groupId}}"
                },
                {
                  "key": "file",
                  "type": "file",
                  "src": "/path/Lab 1-De quy va chien luoc quay lui.pdf"
                }
              ]
            }
          },
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "// ⚠️ TEST CASE NÀY CẦN FILE THẬT.",
                  "// Thay '../path/to/document.pdf' bằng đường dẫn tuyệt đối đến file PDF/PPTX/DOCX trên máy.",
                  "// Ví dụ macOS: /Users/huynhngocbinh/Downloads/sample.pdf",
                  "// Nếu không có file → Newman sẽ trả 400 → bỏ qua assertion này khi chạy tự động."
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "if (json.id) pm.collectionVariables.set('documentId', json.id);"
                ]
              }
            }
          ]
        },
        {
          "name": "❌ Upload tài liệu - không gửi file",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "{{documentBaseUrl}}/",
              "host": ["{{documentBaseUrl}}"],
              "path": [""]
            },
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "title",
                  "value": "Khong co file"
                }
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 400', () => pm.response.to.have.status(400));"
                ]
              }
            }
          ]
        },
        {
          "name": "❌ Upload tài liệu - file vượt quá 100MB (giới hạn multer)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "{{documentBaseUrl}}/",
              "host": ["{{documentBaseUrl}}"],
              "path": [""]
            },
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "title",
                  "value": "File qua lon"
                },
                {
                  "key": "file",
                  "type": "file",
                  "src": "/path/to/oversized-file-over-100mb.zip"
                }
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 400 hoặc 413', () => pm.expect([400, 413]).to.include(pm.response.code));"
                ]
              }
            }
          ]
        },
        {
          "name": "❌ Upload tài liệu - thiếu title",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "{{documentBaseUrl}}/",
              "host": ["{{documentBaseUrl}}"],
              "path": [""]
            },
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "file",
                  "type": "file",
                  "src": "/path/to/document.pdf"
                }
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 400', () => pm.response.to.have.status(400));"
                ]
              }
            }
          ]
        },
        {
          "name": "❌ Upload tài liệu vào group mà mình không phải member - Bị từ chối",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{outsiderToken}}"
              }
            ],
            "url": {
              "raw": "{{documentBaseUrl}}/",
              "host": ["{{documentBaseUrl}}"],
              "path": [""]
            },
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "title",
                  "value": "Upload trai phep"
                },
                {
                  "key": "group_id",
                  "value": "{{groupId}}"
                },
                {
                  "key": "file",
                  "type": "file",
                  "src": "/path/to/document.pdf"
                }
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 400', () => pm.response.to.have.status(400));"
                ]
              }
            }
          ]
        }
      ]
    }
  ],
