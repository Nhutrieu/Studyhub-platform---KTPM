        {
          "name": "✅ Lấy danh sách comment của 1 tài liệu",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "{{documentBaseUrl}}/{{documentId}}/comments?limit=20&offset=0",
              "host": [
                "{{documentBaseUrl}}"
              ],
              "path": [
                "{{documentId}}",
                "comments"
              ],
              "query": [
                {
                  "key": "limit",
                  "value": "20"
                },
                {
                  "key": "offset",
                  "value": "0"
                }
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));"
                ]
              }
            }
          ]
        },
        {
          "name": "❌ Lấy comment của tài liệu private không có quyền - Bị từ chối",
