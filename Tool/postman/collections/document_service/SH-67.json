                "comments"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"content\": \"Tai lieu rat huu ich, cam on ban da chia se!\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "if (json.id) pm.collectionVariables.set('commentId', json.id);"
                ]
              }
            }
          ]
