{
  "info": {
    "name": "SH-65: Kiểm thử Chức năng Cập nhật & Xóa Tài liệu",
    "description": "StudyHub Document Service - SH-65: Kiểm thử Chức năng Cập nhật & Xóa Tài liệu",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "📄 [document-service:3003] Document (/)",
      "item": [
        {
          "name": "🔑 Đăng nhập User thường (Lấy accessToken)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200 - Đăng nhập thành công', () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "const resData = json.data || json;",
                  "if (resData.access_token) {",
                  "    pm.collectionVariables.set('accessToken', resData.access_token);",
                  "    pm.collectionVariables.set('userId', resData.user && resData.user.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{userEmail}}\",\n  \"password\": \"{{password}}\"\n}"
            },
            "url": {
              "raw": "{{authBaseUrl}}/login",
              "host": [
                "{{authBaseUrl}}"
              ],
              "path": [
                "login"
              ]
            }
          }
        },
        {
          "name": "🔑 Đăng nhập Outsider (Lấy outsiderToken)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200 - Đăng nhập thành công', () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "const resData = json.data || json;",
                  "if (resData.access_token) {",
                  "    pm.collectionVariables.set('outsiderToken', resData.access_token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{outsiderEmail}}\",\n  \"password\": \"{{password}}\"\n}"
            },
            "url": {
              "raw": "{{authBaseUrl}}/login",
              "host": [
                "{{authBaseUrl}}"
              ],
              "path": [
                "login"
              ]
            }
          }
        },
        {
          "name": "✅ [Owner tài liệu] Cập nhật thông tin tài liệu",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{documentBaseUrl}}/{{documentId}}",
              "host": [
                "{{documentBaseUrl}}"
              ],
              "path": [
                "{{documentId}}"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Bai giang Giai tich 1 - Chuong 1 (Updated)\",\n  \"description\": \"Cap nhat noi dung\",\n  \"tags\": [\n    \"toan\",\n    \"giai-tich\",\n    \"chuong1\",\n    \"updated\"\n  ]\n}"
            }
          },
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "// PRE-CONDITION: accessToken = user1, documentId = 1111-0001 (doc của user1)",
                  "// Nếu 403: kiểm tra API có dùng userId từ JWT để verify owner không"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "❌ Cập nhật tài liệu của NGƯỜI KHÁC - Bị từ chối",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{outsiderToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{documentBaseUrl}}/{{documentId}}",
              "host": [
                "{{documentBaseUrl}}"
              ],
              "path": [
                "{{documentId}}"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Hacked Title\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 403', () => pm.response.to.have.status(403));"
                ]
              }
            }
          ]
        },
        {
          "name": "❌ Cập nhật tài liệu không tồn tại",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{documentBaseUrl}}/00000000-0000-0000-0000-000000000000",
              "host": [
                "{{documentBaseUrl}}"
              ],
              "path": [
                "00000000-0000-0000-0000-000000000000"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"X\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 403 hoặc 404', () => pm.expect([403, 404]).to.include(pm.response.code));"
                ]
              }
            }
          ]
        },
        {
          "name": "✅ [Owner tài liệu] Xóa tài liệu",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "{{documentBaseUrl}}/{{deletableDocumentId}}",
              "host": [
                "{{documentBaseUrl}}"
              ],
              "path": [
                "{{deletableDocumentId}}"
              ]
            }
          },
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "// PRE-CONDITION: deletableDocumentId = 1111-0002 (Classical Physics, của user1)",
                  "// accessToken = user1 → là owner → phải được phép xóa"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "const res = json.data || json;",
                  "pm.test('deleted = true', () => pm.expect(res.deleted).to.eql(true));"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "❌ Xóa tài liệu của NGƯỜI KHÁC - Bị từ chối",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{outsiderToken}}"
              }
            ],
            "url": {
              "raw": "{{documentBaseUrl}}/{{documentId}}",
              "host": [
                "{{documentBaseUrl}}"
              ],
              "path": [
                "{{documentId}}"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 403', () => pm.response.to.have.status(403));"
                ]
              }
            }
          ]
        }
      ]
    }
  ],
