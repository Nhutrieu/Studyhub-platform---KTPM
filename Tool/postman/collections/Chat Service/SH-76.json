  "item": [
    {
      "name": "Chat Service",
      "item": [
        {
          "name": "[SETUP] Dang nhap admin/user chinh (lay accessToken)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{authBaseUrl}}/login",
              "host": [
                "{{authBaseUrl}}"
              ],
              "path": [
                "login"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{adminEmail}}\",\n  \"password\": \"{{password}}\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200 - dang nhap chinh thanh cong', () => pm.response.to.have.status(200));",
                  "var json = pm.response.json();",
                  "var data = json.data || json;",
                  "pm.collectionVariables.set('accessToken', data.access_token);",
                  "pm.collectionVariables.set('userId', data.user && data.user.id);"
                ]
              }
            }
          ]
        },
        {
          "name": "[SETUP] Dang nhap user nhan tin nhan (lay anotherUserAccessToken)",
          "request": {
            "method": "POST",
            "header": [
