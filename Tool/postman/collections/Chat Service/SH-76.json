                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200 - dang nhap user nhan thanh cong', () => pm.response.to.have.status(200));",
                  "var json = pm.response.json();",
                  "var data = json.data || json;",
                  "pm.collectionVariables.set('anotherUserAccessToken', data.access_token);",
                  "pm.collectionVariables.set('anotherUserId', data.user && data.user.id);"
                ]
              }
            }
          ]
        },
