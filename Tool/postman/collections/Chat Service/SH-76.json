        {
          "name": "[SETUP] Tao/l?y direct conversation admin-user1",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{chatBaseUrl}}/conversations",
              "host": [
                "{{chatBaseUrl}}"
              ],
              "path": [
                "conversations"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"type\": \"direct\",\n  \"target_id\": \"{{anotherUserId}}\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 201 - setup conversation thanh cong', () => pm.response.to.have.status(201));",
                  "var json = pm.response.json();",
                  "pm.collectionVariables.set('conversationId', json.data && (json.data._id || json.data.id));"
                ]
              }
            }
          ]
        },
