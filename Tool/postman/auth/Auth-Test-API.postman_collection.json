  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Register - Success",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 201', function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "",
                  "pm.test('Response has accessToken', function () {",
                  "    var jsonData = pm.response.json();",
                  "    // Tìm accessToken bên trong object data thay vì ở ngoài cùng",
                  "    pm.expect(jsonData.data).to.have.property('accessToken');",
                  "});",
                  "",
                  "if (pm.response.code === 201) {",
                  "    var jsonData = pm.response.json();",
                  "    pm.environment.set('accessToken', jsonData.data.accessToken);",
                  "    pm.environment.set('refreshToken', jsonData.data.refreshToken);",
                  "    pm.environment.set('userId', jsonData.data._id);",
                  "}"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"name\": \"Ca Koi\",\n    \"email\": \"Koi@gmail.com\",\n    \"password\": \"Koi@12345\",\n    \"firstName\": \"Ca\",\n    \"lastName\": \"Koi\",\n    \"phone\": \"0123456788\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/register",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "register"
              ]
            }
          },
          "response": []
        },
